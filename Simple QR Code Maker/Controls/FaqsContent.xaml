<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Simple_QR_Code_Maker.Controls.FaqsContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Simple_QR_Code_Maker.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Simple_QR_Code_Maker.Controls"
    xmlns:m="using:Simple_QR_Code_Maker.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Root"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:EmptyCollectionToVisibilityConverter x:Key="EmptyCollectionToVisibility" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
    </UserControl.Resources>

    <Grid Padding="12,20,20,20">

        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <TextBlock
            Grid.Row="0"
            HorizontalAlignment="Center"
            Style="{StaticResource SubheaderTextBlockStyle}"
            Text="Frequently Asked Questions" />
        <AutoSuggestBox
            Grid.Row="1"
            Margin="20,0"
            PlaceholderText="Search for content in the FAQs..."
            QueryIcon="Find"
            Text="{x:Bind ViewModel.SearchText,
                          Mode=TwoWay}" />
        <Grid Grid.Row="2">
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource BodyTextBlockStyle}"
                Text="No FAQs match the search, try a different term, or send an email"
                TextAlignment="Center"
                TextWrapping="Wrap"
                Visibility="{x:Bind ViewModel.FaqItems.Count,
                                    Converter={StaticResource EmptyCollectionToVisibility},
                                    Mode=OneWay}" />
            <ScrollViewer Name="FaqScroller" Visibility="{x:Bind ViewModel.FaqItems.Count, Converter={StaticResource EmptyCollectionToVisibility}, ConverterParameter=true, Mode=OneWay}">
                <ItemsRepeater Margin="20,0" ItemsSource="{x:Bind ViewModel.FaqItems, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="m:FaqItem">
                            <StackPanel Padding="6,12" Orientation="Vertical">
                                <TextBlock
                                    IsTextSelectionEnabled="True"
                                    Style="{StaticResource SubtitleTextBlockStyle}"
                                    Text="{x:Bind Title,
                                                  Mode=OneTime}"
                                    TextWrapping="WrapWholeWords" />
                                <TextBlock
                                    IsTextSelectionEnabled="True"
                                    Text="{x:Bind Content,
                                                  Mode=OneTime}"
                                    TextWrapping="WrapWholeWords" />
                                <HyperlinkButton
                                    Margin="0,8,0,0"
                                    Padding="0"
                                    Click="FaqActionButton_Click"
                                    Content="{x:Bind ActionText,
                                                     Mode=OneTime}"
                                    Tag="{x:Bind}"
                                    Visibility="{x:Bind ActionText,
                                                        Converter={StaticResource NullToVisibility},
                                                        Mode=OneWay}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </Grid>
        <TextBlock
            Grid.Row="3"
            Padding="24,10"
            Text="Don't see your question or need more information? Feel free to email me and I'll get you an answer"
            TextWrapping="Wrap" />
        <local:IconAndTextButton
            Grid.Row="4"
            HorizontalAlignment="Center"
            Click="IconAndTextButton_Click"
            Text="Email a Question">
            <local:IconAndTextButton.IconSource>
                <SymbolIconSource Symbol="Mail" />
            </local:IconAndTextButton.IconSource>
        </local:IconAndTextButton>
    </Grid>
</UserControl>
