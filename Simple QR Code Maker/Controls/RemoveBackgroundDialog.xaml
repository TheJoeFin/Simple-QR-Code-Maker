<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="Simple_QR_Code_Maker.Controls.RemoveBackgroundDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Remove Background"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    IsPrimaryButtonEnabled="{x:Bind ViewModel.IsPrimaryEnabled, Mode=OneWay}"
    PrimaryButtonText="Apply"
    mc:Ignorable="d">

    <Grid
        MinWidth="460"
        MinHeight="300"
        RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Before / After headers  -->
        <Grid Grid.Row="0" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                HorizontalAlignment="Center"
                FontSize="12"
                FontWeight="SemiBold"
                Text="Original" />
            <TextBlock
                Grid.Column="1"
                HorizontalAlignment="Center"
                FontSize="12"
                FontWeight="SemiBold"
                Text="Background Removed" />
        </Grid>

        <!--  Image previews  -->
        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Padding="4"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4">
                <Image
                    MaxWidth="200"
                    MaxHeight="200"
                    Source="{x:Bind ViewModel.OriginalImageSource, Mode=OneWay}"
                    Stretch="Uniform" />
            </Border>

            <Border
                Grid.Column="1"
                Padding="4"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4">
                <Grid>
                    <Image
                        MaxWidth="200"
                        MaxHeight="200"
                        Source="{x:Bind ViewModel.ResultImageSource, Mode=OneWay}"
                        Stretch="Uniform" />
                    <ProgressRing
                        Width="36"
                        Height="36"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        IsActive="{x:Bind ViewModel.IsProcessing, Mode=OneWay}" />
                </Grid>
            </Border>
        </Grid>

        <!--  Status text  -->
        <TextBlock
            Grid.Row="2"
            HorizontalAlignment="Center"
            FontSize="12"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
            Visibility="{x:Bind ViewModel.StatusVisibility, Mode=OneWay}" />
    </Grid>
</ContentDialog>
