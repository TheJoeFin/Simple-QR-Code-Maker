<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="Simple_QR_Code_Maker.Controls.GenerateIdsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Simple_QR_Code_Maker.Models"
    Title="Generate IDs"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    IsPrimaryButtonEnabled="{x:Bind ViewModel.CanApply,
                                    Mode=OneWay}"
    PrimaryButtonText="Add"
    mc:Ignorable="d">

    <ScrollViewer
        x:Name="DialogScrollViewer"
        MaxHeight="640"
        HorizontalScrollBarVisibility="Disabled"
        HorizontalScrollMode="Disabled"
        VerticalScrollBarVisibility="Auto">
        <Border
            Width="{x:Bind DialogScrollViewer.ActualWidth,
                           Mode=OneWay}"
            MinWidth="420"
            Padding="0,0,12,0">
            <StackPanel HorizontalAlignment="Stretch" Spacing="12">
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Generate one random ID per line and add them into the current text." />

                <NumberBox
                    x:Name="CountNumberBox"
                    Header="How many IDs"
                    Minimum="1"
                    SmallChange="1"
                    SpinButtonPlacementMode="Compact"
                    Value="{x:Bind ViewModel.GeneratedIdCount,
                                   Mode=TwoWay,
                                   UpdateSourceTrigger=PropertyChanged}" />

                <ComboBox
                    Header="ID style"
                    ItemsSource="{x:Bind ViewModel.GeneratedIdFormatOptions,
                                         Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedGeneratedIdFormatOption,
                                          Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="models:SpreadsheetGeneratedIdFormatOption">
                            <TextBlock Text="{x:Bind DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <NumberBox
                    x:Name="NanoIdLengthNumberBox"
                    Header="NanoID length"
                    IsEnabled="{x:Bind ViewModel.IsNanoIdLengthEnabled,
                                       Mode=OneWay}"
                    Minimum="1"
                    SmallChange="1"
                    SpinButtonPlacementMode="Compact"
                    Visibility="{x:Bind ViewModel.NanoIdLengthVisibility,
                                        Mode=OneWay}"
                    Value="{x:Bind ViewModel.NanoIdLength,
                                   Mode=TwoWay,
                                   UpdateSourceTrigger=PropertyChanged}" />

                <TextBox
                    Header="Text before each ID"
                    PlaceholderText="https://example.com/"
                    Text="{x:Bind ViewModel.PrefixText,
                                  Mode=TwoWay,
                                  UpdateSourceTrigger=PropertyChanged}" />

                <TextBox
                    Header="Text after each ID"
                    PlaceholderText="?source=qr-code"
                    Text="{x:Bind ViewModel.SuffixText,
                                  Mode=TwoWay,
                                  UpdateSourceTrigger=PropertyChanged}" />

                <StackPanel Spacing="6">
                    <TextBlock
                        FontSize="14"
                        FontWeight="SemiBold"
                        Text="Preview" />
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind ViewModel.PreviewDescription, Mode=OneWay}" />
                    <TextBox
                        MinHeight="112"
                        AcceptsReturn="True"
                        IsReadOnly="True"
                        Text="{x:Bind ViewModel.PreviewText,
                                      Mode=OneWay}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <InfoBar
                    Title="Check your settings"
                    IsClosable="False"
                    IsOpen="{x:Bind ViewModel.IsValidationVisible,
                                    Mode=OneWay}"
                    Message="{x:Bind ViewModel.ValidationMessage,
                                     Mode=OneWay}"
                    Severity="Error" />
            </StackPanel>
        </Border>
    </ScrollViewer>
</ContentDialog>
