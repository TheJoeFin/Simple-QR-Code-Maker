<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Simple_QR_Code_Maker.Controls.CutOutImagesPaneContentControl"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Simple_QR_Code_Maker.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Simple_QR_Code_Maker.Models"
    xmlns:toolkitConverters="using:CommunityToolkit.WinUI.Converters"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:EmptyCollectionToVisibilityConverter x:Key="EmptyCollectionToVisibility" />
        <toolkitConverters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <Grid
        Background="{ThemeResource LayerFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="0,0,1,0"
        Padding="16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <TextBlock
                MaxWidth="200"
                VerticalAlignment="Center"
                MaxLines="1"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Text="Cut Out Images"
                TextTrimming="CharacterEllipsis" />
            <Button
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Command="{x:Bind ViewModel.CloseCutOutImagesPaneCommand, Mode=OneWay}"
                Style="{StaticResource SubtleButtonStyle}"
                ToolTipService.ToolTip="Close pane">
                <SymbolIcon Symbol="Cancel" />
            </Button>
        </Grid>

        <!--  Image list  -->
        <ListView
            x:Name="CutOutImagesListView"
            Grid.Row="1"
            IsItemClickEnabled="True"
            ItemClick="CutOutImagesListView_ItemClick"
            ItemsSource="{x:Bind ViewModel.DecodingImageItems, Mode=OneWay}"
            SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:DecodingImageItem">
                    <Grid
                        Margin="0,4"
                        ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Width="56"
                            Height="56"
                            VerticalAlignment="Center"
                            Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
                            CornerRadius="4">
                            <Image
                                Source="{x:Bind BitmapImage, Mode=OneWay}"
                                Stretch="Uniform" />
                        </Border>

                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            MaxLines="2"
                            Text="{x:Bind Label, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="Wrap" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
