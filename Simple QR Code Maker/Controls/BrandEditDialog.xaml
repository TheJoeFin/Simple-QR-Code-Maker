<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="Simple_QR_Code_Maker.Controls.BrandEditDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Simple_QR_Code_Maker.Controls"
    xmlns:converters="using:Simple_QR_Code_Maker.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Simple_QR_Code_Maker.Models"
    xmlns:settingsControls="using:CommunityToolkit.WinUI.Controls"
    xmlns:toolkitConverters="using:CommunityToolkit.WinUI.Converters"
    Title="Edit Brand"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    IsPrimaryButtonEnabled="{x:Bind IsNameValid,
                                    Mode=OneWay}"
    PrimaryButtonText="Save"
    mc:Ignorable="d">

    <ContentDialog.Resources>
        <toolkitConverters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:FilePathToImageSourceConverter x:Key="FilePathToImage" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
        <x:Double x:Key="SettingsCardWrapThreshold">320</x:Double>
        <x:Double x:Key="SettingsCardWrapNoIconThreshold">200</x:Double>
    </ContentDialog.Resources>

    <ScrollViewer
        MaxHeight="600"
        Padding="0,0,12,0"
        VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="4">

            <!--  Brand Name  -->
            <settingsControls:SettingsCard Description="Display name for this brand" Header="Brand Name">
                <settingsControls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE8AC;" />
                </settingsControls:SettingsCard.HeaderIcon>
                <TextBox
                    MinWidth="200"
                    PlaceholderText="Brand name"
                    Text="{x:Bind EditName,
                                  Mode=TwoWay,
                                  UpdateSourceTrigger=PropertyChanged}" />
            </settingsControls:SettingsCard>

            <!--  Foreground color  -->
            <settingsControls:SettingsCard Description="Apply a custom foreground color" Header="Foreground color">
                <settingsControls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE790;" />
                </settingsControls:SettingsCard.HeaderIcon>
                <StackPanel
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="12">
                    <controls:ColorPickerButton
                        DefaultImagePath="{x:Bind LogoPath,
                                                  Mode=OneWay}"
                        Visibility="{x:Bind IncludeForeground,
                                            Mode=OneWay,
                                            Converter={StaticResource BoolToVisibility}}"
                        Color="{x:Bind ForegroundColor,
                                       Mode=TwoWay}" />
                    <ToggleSwitch
                        IsOn="{x:Bind IncludeForeground,
                                      Mode=TwoWay}"
                        OffContent=""
                        OnContent="" />
                </StackPanel>
            </settingsControls:SettingsCard>

            <!--  Background color  -->
            <settingsControls:SettingsCard Description="Apply a custom background color" Header="Background color">
                <settingsControls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE771;" />
                </settingsControls:SettingsCard.HeaderIcon>
                <StackPanel
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="12">
                    <controls:ColorPickerButton
                        DefaultImagePath="{x:Bind LogoPath,
                                                  Mode=OneWay}"
                        Visibility="{x:Bind IncludeBackground,
                                            Mode=OneWay,
                                            Converter={StaticResource BoolToVisibility}}"
                        Color="{x:Bind BackgroundColor,
                                       Mode=TwoWay}" />
                    <ToggleSwitch
                        IsOn="{x:Bind IncludeBackground,
                                      Mode=TwoWay}"
                        OffContent=""
                        OnContent="" />
                </StackPanel>
            </settingsControls:SettingsCard>

            <!--  Error correction  -->
            <settingsControls:SettingsCard Description="Set QR code error correction level" Header="Error correction">
                <settingsControls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE8D8;" />
                </settingsControls:SettingsCard.HeaderIcon>
                <StackPanel
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="12">
                    <ComboBox
                        ItemsSource="{x:Bind AllCorrectionLevels,
                                             Mode=OneWay}"
                        SelectedIndex="{x:Bind SelectedCorrectionIndex,
                                               Mode=TwoWay}"
                        Visibility="{x:Bind IncludeErrorCorrection,
                                            Mode=OneWay,
                                            Converter={StaticResource BoolToVisibility}}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="models:ErrorCorrectionOptions">
                                <TextBlock Text="{x:Bind Description}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <ToggleSwitch
                        IsOn="{x:Bind IncludeErrorCorrection,
                                      Mode=TwoWay}"
                        OffContent=""
                        OnContent="" />
                </StackPanel>
            </settingsControls:SettingsCard>

            <!--  Frame  -->
            <settingsControls:SettingsExpander
                Description="Include a frame style and frame text"
                Header="Frame"
                IsExpanded="{x:Bind IncludeFrame,
                                    Mode=OneWay}">
                <settingsControls:SettingsExpander.HeaderIcon>
                    <SymbolIcon
                        RenderTransformOrigin="0.5,0.5"
                        Symbol="CalendarDay">
                        <SymbolIcon.RenderTransform>
                            <ScaleTransform ScaleY="-1" />
                        </SymbolIcon.RenderTransform>
                    </SymbolIcon>
                </settingsControls:SettingsExpander.HeaderIcon>
                <settingsControls:SettingsExpander.Content>
                    <ToggleSwitch
                        IsOn="{x:Bind IncludeFrame,
                                      Mode=TwoWay}"
                        OffContent=""
                        OnContent="" />
                </settingsControls:SettingsExpander.Content>
                <settingsControls:SettingsExpander.Items>
                    <settingsControls:SettingsCard Header="Style">
                        <ComboBox
                            MinWidth="200"
                            ItemsSource="{x:Bind AllFramePresets,
                                                 Mode=OneWay}"
                            SelectedIndex="{x:Bind SelectedFramePresetIndex,
                                                   Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="models:QrFramePresetOption">
                                    <TextBlock Text="{x:Bind Description}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </settingsControls:SettingsCard>
                    <settingsControls:SettingsCard
                        Description="{x:Bind FrameTextDescription, Mode=OneWay}"
                        Header="{x:Bind FrameTextHeader, Mode=OneWay}"
                        Visibility="{x:Bind IsFrameTextVisible,
                                             Mode=OneWay,
                                            Converter={StaticResource BoolToVisibility}}">
                        <TextBox
                            MinWidth="200"
                            PlaceholderText="{x:Bind FrameTextPlaceholder,
                                                     Mode=OneWay}"
                            Text="{x:Bind EditFrameText,
                                          Mode=TwoWay,
                                          UpdateSourceTrigger=PropertyChanged}" />
                    </settingsControls:SettingsCard>
                </settingsControls:SettingsExpander.Items>
            </settingsControls:SettingsExpander>

            <!--  URL / text  -->
            <settingsControls:SettingsExpander
                Description="Include default URL or text content"
                Header="URL / text"
                IsExpanded="{x:Bind IncludeUrl,
                                    Mode=OneWay}">
                <settingsControls:SettingsExpander.HeaderIcon>
                    <FontIcon Glyph="&#xE71B;" />
                </settingsControls:SettingsExpander.HeaderIcon>
                <settingsControls:SettingsExpander.Content>
                    <ToggleSwitch
                        IsOn="{x:Bind IncludeUrl,
                                      Mode=TwoWay}"
                        OffContent=""
                        OnContent="" />
                </settingsControls:SettingsExpander.Content>
                <settingsControls:SettingsExpander.Items>
                    <settingsControls:SettingsCard Header="Content">
                        <TextBox
                            MinWidth="250"
                            PlaceholderText="URL or text content"
                            Text="{x:Bind UrlContent,
                                          Mode=TwoWay,
                                          UpdateSourceTrigger=PropertyChanged}" />
                    </settingsControls:SettingsCard>
                </settingsControls:SettingsExpander.Items>
            </settingsControls:SettingsExpander>

            <!--  Logo image  -->
            <settingsControls:SettingsExpander
                Description="Overlay a logo on the QR code"
                Header="Logo image"
                IsExpanded="{x:Bind IncludeLogo,
                                    Mode=OneWay}">
                <settingsControls:SettingsExpander.HeaderIcon>
                    <SymbolIcon Symbol="Pictures" />
                </settingsControls:SettingsExpander.HeaderIcon>
                <ToggleSwitch
                    IsOn="{x:Bind IncludeLogo,
                                  Mode=TwoWay}"
                    OffContent=""
                    OnContent="" />
                <settingsControls:SettingsExpander.Items>
                    <!--  Image picker  -->
                    <settingsControls:SettingsCard Header="Image">
                        <StackPanel
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="12">
                            <!--  Preview  -->
                            <Grid Width="48" Height="48">
                                <Border
                                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Visibility="{x:Bind LogoPath,
                                                        Converter={StaticResource NullToVisibility},
                                                        ConverterParameter=Inverted,
                                                        Mode=OneWay}">
                                    <Viewbox Width="20" Height="20">
                                        <SymbolIcon Symbol="Pictures" />
                                    </Viewbox>
                                </Border>
                                <Border
                                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Visibility="{x:Bind LogoPath,
                                                        Converter={StaticResource NullToVisibility},
                                                        Mode=OneWay}">
                                    <Image
                                        MaxWidth="44"
                                        MaxHeight="44"
                                        Source="{x:Bind LogoPath,
                                                        Converter={StaticResource FilePathToImage},
                                                        Mode=OneWay}"
                                        Stretch="Uniform" />
                                </Border>
                            </Grid>
                            <Button Command="{x:Bind SelectLogoCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <SymbolIcon Symbol="Pictures" />
                                    <TextBlock Text="Pick Image" />
                                </StackPanel>
                            </Button>
                            <Button
                                Command="{x:Bind ClearLogoCommand}"
                                ToolTipService.ToolTip="Remove logo"
                                Visibility="{x:Bind LogoPath,
                                                    Converter={StaticResource NullToVisibility},
                                                    Mode=OneWay}">
                                <SymbolIcon Symbol="Cancel" />
                            </Button>
                        </StackPanel>
                    </settingsControls:SettingsCard>
                    <!--  Size slider  -->
                    <settingsControls:SettingsCard Description="{x:Bind LogoSizeDescription, Mode=OneWay}" Header="Image Size">
                        <Slider
                            MinWidth="200"
                            Maximum="30"
                            Minimum="7"
                            StepFrequency="1"
                            TickFrequency="5"
                            TickPlacement="BottomRight"
                            Value="{x:Bind LogoSize,
                                           Mode=TwoWay}" />
                    </settingsControls:SettingsCard>
                    <!--  Padding slider  -->
                    <settingsControls:SettingsCard Description="{x:Bind LogoPaddingDescription, Mode=OneWay}" Header="Padding">
                        <Slider
                            MinWidth="200"
                            Maximum="20"
                            Minimum="-20"
                            StepFrequency="1"
                            TickFrequency="8"
                            TickPlacement="BottomRight"
                            Value="{x:Bind LogoPadding,
                                           Mode=TwoWay}" />
                    </settingsControls:SettingsCard>
                </settingsControls:SettingsExpander.Items>
            </settingsControls:SettingsExpander>

        </StackPanel>
    </ScrollViewer>
</ContentDialog>
