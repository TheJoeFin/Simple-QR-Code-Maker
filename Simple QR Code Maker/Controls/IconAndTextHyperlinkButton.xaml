<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Simple_QR_Code_Maker.Controls.IconAndTextHyperlinkButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Root"
    mc:Ignorable="d">

    <HyperlinkButton
        Click="HyperlinkButton_Click"
        Command="{Binding Command, ElementName=Root}"
        CommandParameter="{Binding CommandParameter, ElementName=Root}">
        <StackPanel Orientation="Horizontal" Spacing="10">
            <Viewbox Height="16">
                <ContentPresenter Content="{Binding Icon, ElementName=Root}" />
            </Viewbox>
            <TextBlock Text="{Binding Text, ElementName=Root}" />
        </StackPanel>
    </HyperlinkButton>
</UserControl>
