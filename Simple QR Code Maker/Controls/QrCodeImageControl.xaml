<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Simple_QR_Code_Maker.Controls.QrCodeImageControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Simple_QR_Code_Maker.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid
        Margin="4"
        HorizontalAlignment="Center"
        VerticalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Image
            x:Name="QrCodeImage"
            Width="300"
            Height="300"
            CanDrag="True"
            DragStarting="QrCodeImage_DragStarting"
            Source="{x:Bind Data.CodeAsBitmap,
                            Mode=OneWay}"
            ToolTipService.ToolTip="{x:Bind Data.ToolTipText,
                                            Mode=OneWay}">
            <Image.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem
                        Command="{x:Bind Data.SaveCodePngContextCommand,
                                         Mode=OneWay}"
                        Icon="Save"
                        Text="Save PNG..." />
                    <MenuFlyoutItem
                        Command="{x:Bind Data.CopyCodePngContextCommand,
                                         Mode=OneWay}"
                        Icon="Copy"
                        Text="Copy PNG" />
                    <MenuFlyoutItem
                        Command="{x:Bind Data.ShareCodeContextCommand,
                                         Mode=OneWay}"
                        Icon="Share"
                        Text="Share..." />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem
                        Command="{x:Bind Data.SaveCodeSvgContextCommand,
                                         Mode=OneWay}"
                        Icon="Save"
                        Text="Save SVG..." />
                    <MenuFlyoutItem
                        Command="{x:Bind Data.CopyCodeSvgContextCommand,
                                         Mode=OneWay}"
                        Icon="Copy"
                        Text="Copy SVG" />
                    <MenuFlyoutItem
                        Command="{x:Bind Data.CopyCodeSvgTextContextCommand,
                                         Mode=OneWay}"
                        Icon="Copy"
                        Text="Copy SVG as Text" />
                    <MenuFlyoutSeparator Visibility="{x:Bind BoolToVisibility(Data.IsAutoBranded), Mode=OneWay}" />
                    <MenuFlyoutItem
                        Command="{x:Bind Data.IgnoreAutoBrandContextCommand,
                                         Mode=OneWay}"
                        Text="Use current style"
                        Visibility="{x:Bind BoolToVisibility(Data.IsAutoBranded), Mode=OneWay}">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE8D7;" />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                </MenuFlyout>
            </Image.ContextFlyout>
        </Image>
        <InfoBar
            IsOpen="{x:Bind Data.UrlWarning,
                            Mode=OneWay}"
            Message="QR Code not a URL"
            Severity="Warning"
            ToolTipService.ToolTip="This warning can be disabled in settings" />
        <Border
            Grid.Row="1"
            Padding="8,6"
            Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
            CornerRadius="6"
            Visibility="{x:Bind Data.SizeTextVisible,
                                Mode=TwoWay}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <HyperlinkButton
                    MinWidth="0"
                    Padding="0,2,8,0"
                    VerticalAlignment="Top"
                    Command="{x:Bind Data.FaqButtonCommand,
                                     Mode=OneWay}"
                    ToolTipService.ToolTip="How was this calculated?">
                    <local:RulerIcon />
                </HyperlinkButton>
                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="12">
                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Data.SizeRecommendationTitle, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind Data.SizeRecommendationText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Grid>
            <Border.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem
                        Command="{x:Bind Data.CopySizeTextCommand,
                                         Mode=OneWay}"
                        Icon="Copy"
                        IsEnabled="{x:Bind Data.CanCopySizeText,
                                           Mode=OneWay}"
                        Text="Copy Size" />
                    <MenuFlyoutItem Command="{x:Bind Data.HideSizeTextCommand, Mode=OneWay}" Text="Hide min. size text">
                        <MenuFlyoutItem.Icon>
                            <local:HideIcon />
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                </MenuFlyout>
            </Border.ContextFlyout>
        </Border>
    </Grid>
</UserControl>
