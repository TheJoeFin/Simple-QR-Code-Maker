<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="Simple_QR_Code_Maker.Controls.CsvImportDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Simple_QR_Code_Maker.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Import from CSV"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    IsPrimaryButtonEnabled="{x:Bind IsImportEnabled, Mode=OneWay}"
    PrimaryButtonText="Import"
    mc:Ignorable="d">

    <ContentDialog.Resources>
        <converters:EmptyStringToCollapsedConverter x:Key="EmptyStringToCollapsed" />
    </ContentDialog.Resources>

    <StackPanel MinWidth="540" Spacing="12">

        <!--  Header row toggle  -->
        <ToggleSwitch
            x:Name="HeaderToggle"
            Header="First row is header"
            IsOn="True" />

        <!--  Column selector  -->
        <ComboBox
            x:Name="ColumnComboBox"
            HorizontalAlignment="Stretch"
            Header="Column to import"
            ItemsSource="{x:Bind ColumnNames, Mode=OneWay}"
            SelectedIndex="{x:Bind SelectedColumnIndex, Mode=TwoWay}"
            SelectionChanged="ColumnComboBox_SelectionChanged" />

        <!--  Row count + import count info  -->
        <StackPanel Orientation="Horizontal" Spacing="12">
            <TextBlock
                FontSize="12"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{x:Bind RowCountDescription, Mode=OneWay}" />
            <TextBlock
                FontSize="12"
                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                Text="{x:Bind ImportCountDescription, Mode=OneWay}"
                Visibility="{x:Bind ImportCountDescription, Converter={StaticResource EmptyStringToCollapsed}, Mode=OneWay}" />
        </StackPanel>

        <!--  Preview table — rows and columns built entirely in code-behind  -->
        <Border
            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="4">
            <ScrollViewer
                MaxHeight="320"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Auto">
                <Grid x:Name="PreviewGrid" />
            </ScrollViewer>
        </Border>

    </StackPanel>
</ContentDialog>
