<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Simple_QR_Code_Maker.Controls.FolderPaneContentControl"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Simple_QR_Code_Maker.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Simple_QR_Code_Maker.Models"
    xmlns:toolkitConverters="using:CommunityToolkit.WinUI.Converters"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:EmptyCollectionToVisibilityConverter x:Key="EmptyCollectionToVisibility" />
        <toolkitConverters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <toolkitConverters:BoolNegationConverter x:Key="BoolNegationConverter" />
    </UserControl.Resources>

    <Grid
        Background="{ThemeResource LayerFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="0,0,1,0"
        Padding="16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Header: folder name + close button  -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <StackPanel
                MaxWidth="200"
                VerticalAlignment="Center">
                <TextBlock
                    MaxLines="1"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Text="Folder"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    MaxLines="1"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{x:Bind ViewModel.FolderPaneFolderName, Mode=OneWay}"
                    TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <Button
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Command="{x:Bind ViewModel.CloseFolderPaneCommand, Mode=OneWay}"
                Style="{StaticResource SubtleButtonStyle}"
                ToolTipService.ToolTip="Close folder pane">
                <SymbolIcon Symbol="Cancel" />
            </Button>
        </Grid>

        <!--  Empty state  -->
        <TextBlock
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Style="{StaticResource BodyTextBlockStyle}"
            Text="No image files found in this folder."
            TextAlignment="Center"
            TextWrapping="Wrap"
            Visibility="{x:Bind ViewModel.FolderFiles.Count,
                                Converter={StaticResource EmptyCollectionToVisibility},
                                Mode=OneWay}" />

        <!--  File list  -->
        <ListView
            x:Name="FolderFilesListView"
            Grid.Row="1"
            ItemsSource="{x:Bind ViewModel.FolderFiles, Mode=OneWay}"
            SelectionMode="None"
            Visibility="{x:Bind ViewModel.FolderFiles.Count,
                                Converter={StaticResource EmptyCollectionToVisibility},
                                ConverterParameter=true,
                                Mode=OneWay}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:FolderFileItem">
                    <StackPanel>
                        <!--  File row  -->
                        <Grid
                            Margin="0,4"
                            ColumnSpacing="8"
                            Tapped="FolderFileItem_Tapped"
                            Tag="{x:Bind}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="56" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!--  Thumbnail  -->
                            <Border
                                Width="56"
                                Height="56"
                                VerticalAlignment="Center"
                                Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
                                CornerRadius="4">
                                <Image
                                    Source="{x:Bind Thumbnail, Mode=OneWay}"
                                    Stretch="Uniform" />
                            </Border>

                            <!--  File name  -->
                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                FontWeight="SemiBold"
                                MaxLines="2"
                                Text="{x:Bind FileName}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="Wrap" />
                        </Grid>

                        <!--  Cut-outs (indented below parent)  -->
                        <ItemsControl
                            Margin="12,0,0,4"
                            ItemsSource="{x:Bind CutOuts, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:DecodingImageItem">
                                    <Grid
                                        Margin="0,2"
                                        ColumnSpacing="8"
                                        PointerEntered="CutOutItem_PointerEntered"
                                        PointerExited="CutOutItem_PointerExited"
                                        Tapped="CutOutItem_Tapped"
                                        Tag="{x:Bind}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Width="40"
                                            Height="40"
                                            VerticalAlignment="Center"
                                            Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
                                            CornerRadius="4">
                                            <Image
                                                Source="{x:Bind BitmapImage, Mode=OneWay}"
                                                Stretch="Uniform" />
                                        </Border>
                                        <Grid Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock
                                                Margin="0,0,32,0"
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                MaxLines="2"
                                                Text="{x:Bind Label, Mode=OneWay}"
                                                TextTrimming="CharacterEllipsis"
                                                TextWrapping="Wrap" />
                                            <Button
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Click="SaveCutOutButton_Click"
                                                Tapped="SaveCutOutButton_Tapped"
                                                Opacity="0"
                                                Padding="4"
                                                Style="{StaticResource SubtleButtonStyle}"
                                                Tag="{x:Bind}"
                                                ToolTipService.ToolTip="Save cut-out image">
                                                <FontIcon FontSize="12" Glyph="&#xE74E;" />
                                            </Button>
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!--  Footer buttons  -->
        <StackPanel
            Grid.Row="2"
            Margin="0,8,0,0"
            Spacing="8">
            <Button
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.ShowFolderSummaryCommand, Mode=OneWay}"
                IsEnabled="{x:Bind ViewModel.ShowFolderSummaryCommand.IsRunning,
                                   Mode=OneWay,
                                   Converter={StaticResource BoolNegationConverter}}"
                ToolTipService.ToolTip="Decode all images and view a summary table of results">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <SymbolIcon Symbol="List" />
                    <TextBlock Text="Summary View" />
                </StackPanel>
            </Button>
            <Button
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.DecodeAllAndExportCommand, Mode=OneWay}"
                IsEnabled="{x:Bind ViewModel.DecodeAllAndExportCommand.IsRunning,
                                   Mode=OneWay,
                                   Converter={StaticResource BoolNegationConverter}}"
                ToolTipService.ToolTip="Decode every image in the folder and write a .txt file next to each one">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <SymbolIcon Symbol="Download" />
                    <TextBlock Text="Decode All &amp; Export .txt Files" TextWrapping="Wrap" />
                </StackPanel>
            </Button>
        </StackPanel>

    </Grid>
</UserControl>
