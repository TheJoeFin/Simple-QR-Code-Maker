<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Simple_QR_Code_Maker.Controls.BrandRowItem"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Simple_QR_Code_Maker.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkitConverters="using:CommunityToolkit.WinUI.Converters"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:ColorToBrushConverter x:Key="ColorToBrush" />
        <converters:FilePathToImageSourceConverter x:Key="FilePathToImage" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
        <toolkitConverters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Grid Margin="2" Padding="0,6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Vertical" Spacing="6">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock
                    FontWeight="SemiBold"
                    Style="{StaticResource BodyTextStyle}"
                    Text="{x:Bind Data.Name,
                                  Mode=OneWay}"
                    TextTrimming="CharacterEllipsis" />
                <FontIcon
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                    FontSize="12"
                    Glyph="&#xE734;"
                    ToolTipService.ToolTip="Default brand"
                    Visibility="{x:Bind Data.IsDefault,
                                        Mode=OneWay,
                                        Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>

            <StackPanel
                Grid.Row="1"
                Orientation="Horizontal"
                Spacing="10">
                <StackPanel
                    Orientation="Horizontal"
                    Spacing="4"
                    Visibility="{x:Bind Data.Foreground,
                                        Converter={StaticResource NullToVisibility},
                                        Mode=OneWay}">
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="FG" />
                    <Rectangle
                        Width="16"
                        Height="10"
                        Fill="{x:Bind Data.Foreground,
                                      Converter={StaticResource ColorToBrush},
                                      Mode=OneWay}" />
                </StackPanel>

                <StackPanel
                    Orientation="Horizontal"
                    Spacing="4"
                    Visibility="{x:Bind Data.Background,
                                        Converter={StaticResource NullToVisibility},
                                        Mode=OneWay}">
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="BG" />
                    <Rectangle
                        Width="16"
                        Height="10"
                        Fill="{x:Bind Data.Background,
                                      Converter={StaticResource ColorToBrush},
                                      Mode=OneWay}" />
                </StackPanel>

                <StackPanel
                    Orientation="Horizontal"
                    Spacing="4"
                    Visibility="{x:Bind Data.ErrorCorrectionLevelAsString,
                                        Converter={StaticResource NullToVisibility},
                                        Mode=OneWay}">
                    <FontIcon
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                        FontSize="11"
                        Glyph="&#xE8D8;" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind Data.ErrorCorrectionLevelAsString,
                                      Mode=OneWay}" />
                </StackPanel>

                <StackPanel
                    Orientation="Horizontal"
                    Spacing="4"
                    Visibility="{x:Bind Data.UrlContent,
                                        Converter={StaticResource NullToVisibility},
                                        Mode=OneWay}">
                    <FontIcon
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                        FontSize="11"
                        Glyph="&#xE71B;" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="Text" />
                </StackPanel>
            </StackPanel>

            <TextBlock
                Grid.Row="2"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{x:Bind Data.CreatedDateAsString,
                              Mode=OneWay}"
                TextTrimming="CharacterEllipsis" />
        </StackPanel>

        <StackPanel
            Grid.RowSpan="3"
            Grid.Column="1"
            Margin="12,0,0,0"
            VerticalAlignment="Center"
            Orientation="Horizontal"
            Spacing="6">
            <Border
                Width="36"
                Height="36"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Visibility="{x:Bind Data.LogoImagePath,
                                    Converter={StaticResource NullToVisibility},
                                    Mode=OneWay}">
                <Image
                    Width="32"
                    Height="32"
                    Margin="1"
                    Source="{x:Bind Data.LogoImagePath,
                                    Converter={StaticResource FilePathToImage},
                                    Mode=OneWay}"
                    Stretch="Uniform" />
            </Border>

            <Button
                Width="32"
                Height="32"
                MinWidth="32"
                Padding="0"
                ToolTipService.ToolTip="Brand options"
                Visibility="{x:Bind ShowActions,
                                    Mode=OneWay,
                                    Converter={StaticResource BoolToVisibility}}">
                <Button.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem
                            Click="EditMenuItem_Click"
                            Icon="Edit"
                            Text="Edit" />
                        <MenuFlyoutItem
                            Click="SetDefaultMenuItem_Click"
                            Text="Set as default" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem
                            Click="DeleteMenuItem_Click"
                            Icon="Delete"
                            Text="Delete" />
                    </MenuFlyout>
                </Button.Flyout>
                <FontIcon
                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                    Glyph="&#xE712;" />
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
