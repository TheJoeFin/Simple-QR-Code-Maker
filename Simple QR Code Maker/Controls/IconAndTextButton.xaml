<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Simple_QR_Code_Maker.Controls.IconAndTextButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Root"
    mc:Ignorable="d">

    <Button
        Click="Button_Click"
        Command="{x:Bind Command, Mode=OneWay}"
        CommandParameter="{x:Bind CommandParameter, Mode=OneWay}">
        <StackPanel Orientation="Horizontal" Spacing="10">
            <Viewbox Height="16">
                <Grid>
                    <ContentPresenter x:Name="ExplicitIconPresenter" />
                    <IconSourceElement x:Name="IconSourcePresenter" />
                </Grid>
            </Viewbox>
            <TextBlock Text="{x:Bind DisplayText, Mode=OneWay}" />
        </StackPanel>
    </Button>
</UserControl>
