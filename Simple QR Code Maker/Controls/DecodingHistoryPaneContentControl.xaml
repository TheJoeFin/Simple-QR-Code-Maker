<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Simple_QR_Code_Maker.Controls.DecodingHistoryPaneContentControl"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Simple_QR_Code_Maker.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Simple_QR_Code_Maker.Models"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:EmptyCollectionToVisibilityConverter x:Key="EmptyCollectionToVisibility" />
        <converters:FilePathToImageSourceConverter x:Key="FilePathToImage" />
    </UserControl.Resources>

    <Grid
        Background="{ThemeResource LayerFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1,0,0,0"
        Padding="16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,8">
            <TextBlock
                VerticalAlignment="Center"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Text="Decoding History" />
            <HyperlinkButton
                HorizontalAlignment="Right"
                Command="{x:Bind ViewModel.ClearDecodingHistoryCommand, Mode=OneWay}"
                IsEnabled="{x:Bind ViewModel.HasDecodingHistory, Mode=OneWay}"
                ToolTipService.ToolTip="Clear all decoding history">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <SymbolIcon Symbol="Delete" />
                    <TextBlock Text="Clear" />
                </StackPanel>
            </HyperlinkButton>
        </Grid>

        <TextBlock
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Style="{StaticResource BodyTextBlockStyle}"
            Text="No decoding history yet. Open, paste, or capture an image to decode."
            TextAlignment="Center"
            TextWrapping="Wrap"
            Visibility="{x:Bind ViewModel.DecodingHistoryItems.Count,
                                Converter={StaticResource EmptyCollectionToVisibility},
                                Mode=OneWay}" />

        <ListView
            x:Name="HistoryListView"
            Grid.Row="1"
            IsItemClickEnabled="True"
            ItemClick="HistoryListView_ItemClick"
            ItemsSource="{x:Bind ViewModel.DecodingHistoryItems, Mode=OneWay}"
            SelectionMode="None"
            Visibility="{x:Bind ViewModel.DecodingHistoryItems.Count,
                                Converter={StaticResource EmptyCollectionToVisibility},
                                ConverterParameter=true,
                                Mode=OneWay}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:DecodingHistoryItem">
                    <Grid
                        Margin="0,4"
                        ColumnSpacing="8"
                        RowSpacing="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!--  Thumbnail  -->
                        <Border
                            Width="56"
                            Height="56"
                            VerticalAlignment="Center"
                            Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
                            CornerRadius="4">
                            <Image
                                Source="{x:Bind SavedImagePath, Converter={StaticResource FilePathToImage}}"
                                Stretch="Uniform" />
                        </Border>

                        <!--  Info  -->
                        <StackPanel
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Spacing="2">
                            <TextBlock
                                FontWeight="SemiBold"
                                MaxLines="1"
                                Text="{x:Bind SourceDisplayName}"
                                TextTrimming="CharacterEllipsis" />
                            <StackPanel Orientation="Horizontal" Spacing="0">
                                <TextBlock
                                    MaxLines="2"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind FirstDecodedText}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    FontStyle="Italic"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Text="{x:Bind DecodedCountSuffix}" />
                            </StackPanel>
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{x:Bind SaveDateAsString}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
