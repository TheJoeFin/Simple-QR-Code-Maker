<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Simple_QR_Code_Maker.Controls.ImageColorPickerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Simple_QR_Code_Maker.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:ColorToBrushConverter x:Key="ColorToBrush" />
    </UserControl.Resources>

    <StackPanel Width="300" Spacing="8">

        <!--  Pick image button  -->
        <Button
            x:Name="PickImageButton"
            HorizontalAlignment="Left"
            Click="PickImageButton_Click">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <SymbolIcon Symbol="Pictures" />
                <TextBlock Text="Pick Image" />
            </StackPanel>
        </Button>

        <!--  Image display area: 280×200, letterboxed  -->
        <Grid
            x:Name="ImageArea"
            Width="280"
            Height="200"
            Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
            CornerRadius="4">

            <!--  Image displayed with Stretch=Uniform  -->
            <Image
                x:Name="PreviewImage"
                Width="280"
                Height="200"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Stretch="Uniform" />

            <!--  Placeholder shown when no image is loaded  -->
            <StackPanel
                x:Name="NoImagePlaceholder"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Opacity="0.4"
                Spacing="6">
                <Viewbox Width="40" Height="40">
                    <SymbolIcon Symbol="Pictures" />
                </Viewbox>
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="12"
                    Text="No image loaded" />
            </StackPanel>

            <!--  Crosshair overlay: IsHitTestVisible=False so pointer events reach PointerOverlay  -->
            <Canvas
                x:Name="CrosshairCanvas"
                Width="280"
                Height="200"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                IsHitTestVisible="False">

                <!--  Dark shadow lines for contrast  -->
                <Line
                    x:Name="CrosshairHShadow"
                    Opacity="0.5"
                    Stroke="Black"
                    StrokeThickness="3"
                    Visibility="Collapsed" />
                <Line
                    x:Name="CrosshairVShadow"
                    Opacity="0.5"
                    Stroke="Black"
                    StrokeThickness="3"
                    Visibility="Collapsed" />

                <!--  White crosshair lines  -->
                <Line
                    x:Name="CrosshairH"
                    Stroke="White"
                    StrokeThickness="1"
                    Visibility="Collapsed" />
                <Line
                    x:Name="CrosshairV"
                    Stroke="White"
                    StrokeThickness="1"
                    Visibility="Collapsed" />

                <!--  Small color preview swatch near cursor  -->
                <Border
                    x:Name="ColorPreviewSwatch"
                    Width="22"
                    Height="22"
                    BorderBrush="White"
                    BorderThickness="2"
                    CornerRadius="3"
                    Visibility="Collapsed" />
            </Canvas>

            <!--  Transparent overlay captures all pointer events  -->
            <Grid
                x:Name="PointerOverlay"
                Width="280"
                Height="200"
                Background="Transparent"
                PointerExited="PointerOverlay_PointerExited"
                PointerMoved="PointerOverlay_PointerMoved"
                PointerPressed="PointerOverlay_PointerPressed" />

        </Grid>

        <!--  Suggested colors — visible only after an image is loaded  -->
        <StackPanel
            x:Name="SuggestedColorsPanel"
            Spacing="6"
            Visibility="Collapsed">
            <TextBlock
                FontSize="12"
                FontWeight="SemiBold"
                Text="Suggested colors" />
            <StackPanel
                x:Name="SwatchRow"
                Orientation="Horizontal"
                Spacing="6" />
        </StackPanel>

    </StackPanel>
</UserControl>
