<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Simple_QR_Code_Maker.Controls.AdvancedToolsUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Simple_QR_Code_Maker.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Simple_QR_Code_Maker.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkitConverters="using:CommunityToolkit.WinUI.Converters"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <toolkitConverters:BoolNegationConverter x:Key="BoolNegationConverter" />
        <toolkitConverters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,12,0,8" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Scrollable Content  -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="12,12,12,0">
            <StackPanel Spacing="12">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Advanced Image Processing Tools" />

        <StackPanel
            Padding="12"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="8"
            Spacing="8">
            <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Basic Adjustments" />

            <CheckBox
                x:Name="GrayscaleCheckBox"
                Content="Convert to Grayscale"
                IsChecked="{x:Bind ViewModel.IsGrayscaleEnabled, Mode=TwoWay}"
                ToolTipService.ToolTip="Convert the image to grayscale for better QR code detection" />

            <StackPanel Spacing="4">
                <TextBlock Text="Contrast" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Slider
                        x:Name="ContrastSlider"
                        Grid.Column="0"
                        Maximum="100"
                        Minimum="-100"
                        StepFrequency="1"
                        ToolTipService.ToolTip="Adjust image contrast"
                        Value="{x:Bind ViewModel.ContrastValue, Mode=TwoWay}" />
                    <TextBlock
                        Grid.Column="1"
                        MinWidth="40"
                        VerticalAlignment="Center"
                        Text="{x:Bind ViewModel.ContrastValue, Mode=OneWay}" />
                </Grid>
            </StackPanel>
        </StackPanel>

        <StackPanel
            Padding="12"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="8"
            Spacing="8">
            <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Levels Adjustment" />

            <StackPanel Spacing="4">
                <TextBlock Text="Black Point" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Slider
                        x:Name="BlackPointSlider"
                        Grid.Column="0"
                        Maximum="100"
                        Minimum="0"
                        StepFrequency="1"
                        ToolTipService.ToolTip="Adjust the black point level"
                        Value="{x:Bind ViewModel.BlackPointLevel, Mode=TwoWay}" />
                    <TextBlock
                        Grid.Column="1"
                        MinWidth="40"
                        VerticalAlignment="Center"
                        Text="{x:Bind ViewModel.BlackPointLevel, Mode=OneWay}" />
                </Grid>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="White Point" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Slider
                        x:Name="WhitePointSlider"
                        Grid.Column="0"
                        Maximum="100"
                        Minimum="0"
                        StepFrequency="1"
                        ToolTipService.ToolTip="Adjust the white point level"
                        Value="{x:Bind ViewModel.WhitePointLevel, Mode=TwoWay}" />
                    <TextBlock
                        Grid.Column="1"
                        MinWidth="40"
                        VerticalAlignment="Center"
                        Text="{x:Bind ViewModel.WhitePointLevel, Mode=OneWay}" />
                </Grid>
            </StackPanel>
        </StackPanel>

        <StackPanel
            Padding="12"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="8"
            Spacing="8">
            <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Eyedropper Tools" />

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button
                        Command="{x:Bind ViewModel.ToggleEyedropperBlackModeCommand}"
                        ToolTipService.ToolTip="Click to enable eyedropper, then click on the image to select the black point">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xEF3C;" />
                            <TextBlock Text="Pick Black Point" />
                        </StackPanel>
                    </Button>

                    <Button
                        Command="{x:Bind ViewModel.ToggleEyedropperWhiteModeCommand}"
                        ToolTipService.ToolTip="Click to enable eyedropper, then click on the image to select the white point">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xEF3C;" />
                            <TextBlock Text="Pick White Point" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <InfoBar
                    IsClosable="False"
                    IsOpen="{x:Bind ViewModel.IsEyedropperBlackMode, Mode=OneWay}"
                    Message="Click on the image to select the black point"
                    Severity="Informational" />

                <InfoBar
                    IsClosable="False"
                    IsOpen="{x:Bind ViewModel.IsEyedropperWhiteMode, Mode=OneWay}"
                    Message="Click on the image to select the white point"
                    Severity="Informational" />

                <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                    <StackPanel Spacing="4" Visibility="{x:Bind ViewModel.SelectedBlackPointColor, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                        <TextBlock Text="Black Point Color" FontSize="12" />
                        <Border
                            Width="60"
                            Height="30"
                            BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <Border.Background>
                                <SolidColorBrush Color="Black" />
                            </Border.Background>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="4" Visibility="{x:Bind ViewModel.SelectedWhitePointColor, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                        <TextBlock Text="White Point Color" FontSize="12" />
                        <Border
                            Width="60"
                            Height="30"
                            BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <Border.Background>
                                <SolidColorBrush Color="White" />
                            </Border.Background>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

        <StackPanel
            Padding="12"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="8"
            Spacing="8">
            <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Perspective Correction" />

            <CheckBox
                x:Name="PerspectiveModeCheckBox"
                Content="Enable Perspective Correction Mode"
                IsChecked="{x:Bind ViewModel.IsPerspectiveCorrectionMode, Mode=TwoWay}"
                ToolTipService.ToolTip="Enable to select the 4 corners of the QR code for perspective correction" />

            <InfoBar
                IsClosable="False"
                IsOpen="{x:Bind ViewModel.IsPerspectiveCorrectionMode, Mode=OneWay}"
                Message="Click on the image to mark each corner in sequence"
                Severity="Informational" />

            <!-- Current step indicator -->
            <StackPanel 
                Margin="0,8,0,0" 
                Orientation="Horizontal" 
                Spacing="8" 
                Visibility="{x:Bind ViewModel.IsPerspectiveCorrectionMode, Mode=OneWay}">

                <!-- Number badge -->
                <Border
                    Width="28"
                    Height="28"
                    Background="{ThemeResource SystemAccentColor}"
                    CornerRadius="14"
                    Visibility="{x:Bind ViewModel.IsCornerSelectionComplete, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=inverse}">
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="{x:Bind ViewModel.CurrentCornerNumber, Mode=OneWay}" />
                </Border>

                <!-- Success checkmark -->
                <Border
                    Width="28"
                    Height="28"
                    Background="{ThemeResource SystemFillColorSuccessBrush}"
                    CornerRadius="14"
                    Visibility="{x:Bind ViewModel.IsCornerSelectionComplete, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <FontIcon 
                        FontSize="14" 
                        Foreground="White" 
                        Glyph="&#xE73E;" />
                </Border>

                <!-- Instruction text -->
                <TextBlock
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource SystemAccentColor}"
                    Text="{x:Bind ViewModel.CurrentCornerInstruction, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.IsCornerSelectionComplete, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=inverse}" />

                <TextBlock
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                    Text="{x:Bind ViewModel.CurrentCornerInstruction, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.IsCornerSelectionComplete, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>

            <StackPanel Spacing="4" Visibility="{x:Bind ViewModel.IsPerspectiveCorrectionMode, Mode=OneWay}">
                <TextBlock Text="Border Size (pixels)" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Slider
                        x:Name="BorderSlider"
                        Grid.Column="0"
                        Maximum="50"
                        Minimum="0"
                        StepFrequency="1"
                        ToolTipService.ToolTip="Add a white border around the corrected image for better detection"
                        Value="{x:Bind ViewModel.BorderPixels, Mode=TwoWay}" />
                    <TextBlock
                        Grid.Column="1"
                        MinWidth="40"
                        VerticalAlignment="Center"
                        Text="{x:Bind ViewModel.BorderPixels, Mode=OneWay}" />
                </Grid>
            </StackPanel>

                        <Button
                            Command="{x:Bind ViewModel.ClearPerspectiveCornersCommand}"
                            Content="Clear Corner Selection"
                            ToolTipService.ToolTip="Clear all selected corners to start over" />
                    </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!--  Fixed Action Buttons  -->
                    <StackPanel
                        Grid.Row="1"
                        Padding="12"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="0,1,0,0"
                        Orientation="Horizontal"
                        Spacing="12">
                        <Button
                            Command="{x:Bind ViewModel.ApplyProcessingCommand}"
                            IsEnabled="{x:Bind ViewModel.IsProcessing, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                            Style="{StaticResource AccentButtonStyle}"
                            ToolTipService.ToolTip="Apply all selected adjustments to the image">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ProgressRing 
                                    Width="16" 
                                    Height="16" 
                                    IsActive="{x:Bind ViewModel.IsProcessing, Mode=OneWay}"
                                    Visibility="{x:Bind ViewModel.IsProcessing, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <SymbolIcon 
                                    Symbol="Accept"
                                    Visibility="{x:Bind ViewModel.IsProcessing, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=inverse}" />
                                <TextBlock Text="Apply Changes" />
                            </StackPanel>
                        </Button>

                        <Button
                            Command="{x:Bind ViewModel.ResetAllSettingsCommand}"
                            IsEnabled="{x:Bind ViewModel.IsProcessing, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                            ToolTipService.ToolTip="Reset all settings to default values">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <SymbolIcon Symbol="Refresh" />
                                <TextBlock Text="Reset All" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </UserControl>
