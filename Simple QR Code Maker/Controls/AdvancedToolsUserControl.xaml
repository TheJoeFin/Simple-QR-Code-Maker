<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Simple_QR_Code_Maker.Controls.AdvancedToolsUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Simple_QR_Code_Maker.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Simple_QR_Code_Maker.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:settingsControls="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolNegationConverter x:Key="BoolNegationConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <x:Double x:Key="SettingsCardWrapThreshold">320</x:Double>
        <x:Double x:Key="SettingsCardWrapNoIconThreshold">200</x:Double>

        <Style x:Key="WorkflowLauncherButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <ScrollViewer
                Padding="16,16,16,0"
                VerticalScrollBarVisibility="Auto"
                Visibility="{x:Bind ViewModel.IsWorkflowPickerVisible,
                                    Mode=OneWay,
                                    Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Spacing="12">
                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource OverlayCornerRadius}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Width="40"
                                Height="40"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="20">
                                <SymbolIcon
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Symbol="Repair" />
                            </Border>

                            <StackPanel
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Spacing="4">
                                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Advanced decoding" />
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="Choose a focused workflow or make quick image adjustments before decoding."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <settingsControls:SettingsExpander
                        Description="Make quick, non-guided image adjustments."
                        Header="Quick fixes"
                        IsExpanded="True">
                        <settingsControls:SettingsExpander.HeaderIcon>
                            <FontIcon Glyph="&#xE793;" />
                        </settingsControls:SettingsExpander.HeaderIcon>
                        <settingsControls:SettingsExpander.Items>
                            <settingsControls:SettingsCard Header="One-tap fixes">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Button
                                        Grid.Column="0"
                                        Width="360"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Command="{x:Bind ViewModel.ApplyGrayscaleCommand}"
                                        IsEnabled="{x:Bind ViewModel.IsProcessing,
                                                           Mode=OneWay,
                                                           Converter={StaticResource BoolNegationConverter}}"
                                        ToolTipService.ToolTip="Convert the image to grayscale for better QR code detection">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE790;" />
                                            <TextBlock Text="Grayscale" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Button>

                                    <Button
                                        Grid.Column="1"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Command="{x:Bind ViewModel.ApplyInvertCommand}"
                                        IsEnabled="{x:Bind ViewModel.IsProcessing,
                                                           Mode=OneWay,
                                                           Converter={StaticResource BoolNegationConverter}}"
                                        ToolTipService.ToolTip="Invert image colors when the code is lighter than its background">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE771;" />
                                            <TextBlock Text="Invert" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </settingsControls:SettingsCard>

                            <settingsControls:SettingsCard Header="Contrast">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Slider
                                        x:Name="ContrastSlider"
                                        Grid.Column="0"
                                        Maximum="100"
                                        Minimum="-100"
                                        StepFrequency="1"
                                        ToolTipService.ToolTip="Increase or decrease contrast to separate the code from its background"
                                        Value="{x:Bind ViewModel.ContrastValue,
                                                       Mode=TwoWay}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        MinWidth="40"
                                        VerticalAlignment="Center"
                                        Text="{x:Bind ViewModel.ContrastValue,
                                                      Mode=OneWay}" />
                                </Grid>
                            </settingsControls:SettingsCard>

                            <settingsControls:SettingsCard Header="Black point">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Slider
                                        x:Name="BlackPointSlider"
                                        Grid.Column="0"
                                        Maximum="100"
                                        Minimum="0"
                                        StepFrequency="1"
                                        ToolTipService.ToolTip="Set how dark a pixel needs to be before it becomes black"
                                        Value="{x:Bind ViewModel.BlackPointLevel,
                                                       Mode=TwoWay}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        MinWidth="40"
                                        VerticalAlignment="Center"
                                        Text="{x:Bind ViewModel.BlackPointLevel,
                                                      Mode=OneWay}" />
                                </Grid>
                            </settingsControls:SettingsCard>

                            <settingsControls:SettingsCard Header="White point">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Slider
                                        x:Name="WhitePointSlider"
                                        Grid.Column="0"
                                        Maximum="100"
                                        Minimum="0"
                                        StepFrequency="1"
                                        ToolTipService.ToolTip="Set how bright a pixel needs to be before it becomes white"
                                        Value="{x:Bind ViewModel.WhitePointLevel,
                                                       Mode=TwoWay}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        MinWidth="40"
                                        VerticalAlignment="Center"
                                        Text="{x:Bind ViewModel.WhitePointLevel,
                                                      Mode=OneWay}" />
                                </Grid>
                            </settingsControls:SettingsCard>

                            <settingsControls:SettingsCard Header="Apply quick fixes">
                                <Button
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Command="{x:Bind ViewModel.ApplyProcessingCommand}"
                                    IsEnabled="{x:Bind ViewModel.IsProcessing,
                                                       Mode=OneWay,
                                                       Converter={StaticResource BoolNegationConverter}}"
                                    Style="{StaticResource AccentButtonStyle}"
                                    ToolTipService.ToolTip="Apply the current quick-fix settings to the image">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Grid Width="16" Height="16">
                                            <FontIcon
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                Glyph="&#xE73E;"
                                                Visibility="{x:Bind ViewModel.IsProcessing,
                                                                    Mode=OneWay,
                                                                    Converter={StaticResource BoolToVisibilityConverter},
                                                                    ConverterParameter=inverse}" />
                                            <ProgressRing
                                                Width="16"
                                                Height="16"
                                                IsActive="{x:Bind ViewModel.IsProcessing,
                                                                  Mode=OneWay}"
                                                Visibility="{x:Bind ViewModel.IsProcessing,
                                                                    Mode=OneWay,
                                                                    Converter={StaticResource BoolToVisibilityConverter}}" />
                                        </Grid>

                                        <TextBlock
                                            Grid.Column="1"
                                            Text="Apply quick fixes"
                                            TextWrapping="Wrap" />

                                        <Ellipse
                                            Grid.Column="2"
                                            Width="8"
                                            Height="8"
                                            VerticalAlignment="Center"
                                            Fill="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                            Visibility="{x:Bind ViewModel.HasPendingChanges,
                                                                Mode=OneWay,
                                                                Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </Grid>
                                </Button>
                            </settingsControls:SettingsCard>
                        </settingsControls:SettingsExpander.Items>
                    </settingsControls:SettingsExpander>

                    <settingsControls:SettingsExpander
                        Description="Open a focused tool flow and return here when finished."
                        Header="Guided workflows"
                        IsExpanded="True">
                        <settingsControls:SettingsExpander.HeaderIcon>
                            <SymbolIcon Symbol="Edit" />
                        </settingsControls:SettingsExpander.HeaderIcon>
                        <settingsControls:SettingsExpander.Items>
                            <settingsControls:SettingsCard Description="Click a dark pixel and apply that sample immediately." Header="Sample black point">
                                <Button
                                    Command="{x:Bind ViewModel.OpenBlackPointWorkflowCommand}"
                                    IsEnabled="{x:Bind ViewModel.IsProcessing,
                                                       Mode=OneWay,
                                                       Converter={StaticResource BoolNegationConverter}}"
                                    Style="{StaticResource WorkflowLauncherButtonStyle}"
                                    ToolTipService.ToolTip="Open the black-point sampling workflow">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xEF3C;" />
                                        <TextBlock Text="Pick Black Point" />
                                    </StackPanel>
                                </Button>
                            </settingsControls:SettingsCard>

                            <settingsControls:SettingsCard Description="Click a light pixel and apply that sample immediately." Header="Sample white point">
                                <Button
                                    Command="{x:Bind ViewModel.OpenWhitePointWorkflowCommand}"
                                    IsEnabled="{x:Bind ViewModel.IsProcessing,
                                                       Mode=OneWay,
                                                       Converter={StaticResource BoolNegationConverter}}"
                                    Style="{StaticResource WorkflowLauncherButtonStyle}"
                                    ToolTipService.ToolTip="Open the white-point sampling workflow">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xEF3C;" />
                                        <TextBlock Text="White Black Point" />
                                    </StackPanel>
                                </Button>
                            </settingsControls:SettingsCard>

                            <settingsControls:SettingsCard Description="Mark all four corners, then apply the correction." Header="Straighten a QR code">
                                <Button
                                    Command="{x:Bind ViewModel.OpenPerspectiveWorkflowCommand}"
                                    IsEnabled="{x:Bind ViewModel.IsProcessing,
                                                       Mode=OneWay,
                                                       Converter={StaticResource BoolNegationConverter}}"
                                    Style="{StaticResource WorkflowLauncherButtonStyle}"
                                    ToolTipService.ToolTip="Open the perspective correction workflow">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <local:QrCodeIcon />
                                        <TextBlock Text="Pick Code Corners" />
                                    </StackPanel>
                                </Button>
                            </settingsControls:SettingsCard>

                            <settingsControls:SettingsCard Description="Draw a region on the image, then extract it as a new image." Header="Extract a region">
                                <Button
                                    Command="{x:Bind ViewModel.OpenCutOutWorkflowCommand}"
                                    IsEnabled="{x:Bind ViewModel.IsProcessing,
                                                       Mode=OneWay,
                                                       Converter={StaticResource BoolNegationConverter}}"
                                    Style="{StaticResource WorkflowLauncherButtonStyle}"
                                    ToolTipService.ToolTip="Open the extract-region workflow">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <SymbolIcon Symbol="Crop" />
                                        <TextBlock Text="Cutout area" />
                                    </StackPanel>
                                </Button>
                            </settingsControls:SettingsCard>
                        </settingsControls:SettingsExpander.Items>
                    </settingsControls:SettingsExpander>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer
                Padding="16,16,16,0"
                VerticalScrollBarVisibility="Auto"
                Visibility="{x:Bind ViewModel.IsSampleBlackPointWorkflowVisible,
                                    Mode=OneWay,
                                    Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Spacing="12">
                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource OverlayCornerRadius}">
                        <StackPanel Spacing="4">
                            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Sample black point" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="Click the darkest meaningful part of the code or background. The sample is applied as soon as you pick it."
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <InfoBar
                        IsClosable="False"
                        IsOpen="True"
                        Message="Click once on the image to choose the black point."
                        Severity="Informational" />
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer
                Padding="16,16,16,0"
                VerticalScrollBarVisibility="Auto"
                Visibility="{x:Bind ViewModel.IsSampleWhitePointWorkflowVisible,
                                    Mode=OneWay,
                                    Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Spacing="12">
                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource OverlayCornerRadius}">
                        <StackPanel Spacing="4">
                            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Sample white point" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="Click the lightest meaningful part of the code or background. The sample is applied as soon as you pick it."
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <InfoBar
                        IsClosable="False"
                        IsOpen="True"
                        Message="Click once on the image to choose the white point."
                        Severity="Informational" />
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer
                Padding="16,16,16,0"
                VerticalScrollBarVisibility="Auto"
                Visibility="{x:Bind ViewModel.IsPerspectiveWorkflowVisible,
                                    Mode=OneWay,
                                    Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Spacing="12">
                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource OverlayCornerRadius}">
                        <StackPanel Spacing="4">
                            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Straighten a QR code" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="Work through the corner selection steps, then apply the correction when the outline is complete."
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <InfoBar
                        IsClosable="False"
                        IsOpen="True"
                        Message="Click each corner on the image in order."
                        Severity="Informational" />

                    <settingsControls:SettingsCard Header="Current step">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border
                                Width="28"
                                Height="28"
                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                CornerRadius="14"
                                Visibility="{x:Bind ViewModel.IsCornerSelectionComplete,
                                                    Mode=OneWay,
                                                    Converter={StaticResource BoolToVisibilityConverter},
                                                    ConverterParameter=inverse}">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                    Style="{StaticResource BodyStrongTextBlockStyle}"
                                    Text="{x:Bind ViewModel.CurrentCornerNumber,
                                                  Mode=OneWay}" />
                            </Border>

                            <Border
                                Width="28"
                                Height="28"
                                Background="{ThemeResource SystemFillColorSuccessBrush}"
                                CornerRadius="14"
                                Visibility="{x:Bind ViewModel.IsCornerSelectionComplete,
                                                    Mode=OneWay,
                                                    Converter={StaticResource BoolToVisibilityConverter}}">
                                <FontIcon
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                    Glyph="&#xE73E;" />
                            </Border>

                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Style="{StaticResource BodyStrongTextBlockStyle}"
                                Text="{x:Bind ViewModel.CurrentCornerInstruction,
                                              Mode=OneWay}"
                                TextWrapping="Wrap" />
                        </Grid>
                    </settingsControls:SettingsCard>

                    <settingsControls:SettingsCard Header="Border size">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Slider
                                x:Name="BorderSlider"
                                Grid.Column="0"
                                Maximum="50"
                                Minimum="0"
                                StepFrequency="1"
                                ToolTipService.ToolTip="Add white padding around the corrected image to improve detection"
                                Value="{x:Bind ViewModel.BorderPixels,
                                               Mode=TwoWay}" />
                            <TextBlock
                                Grid.Column="1"
                                MinWidth="40"
                                VerticalAlignment="Center"
                                Text="{x:Bind ViewModel.BorderPixels,
                                              Mode=OneWay}" />
                        </Grid>
                    </settingsControls:SettingsCard>

                    <settingsControls:SettingsCard Header="Selection">
                        <Button
                            HorizontalAlignment="Stretch"
                            Command="{x:Bind ViewModel.ClearPerspectiveCornersCommand}"
                            ToolTipService.ToolTip="Clear all selected corners and start over">
                            <TextBlock Text="Clear corners" />
                        </Button>
                    </settingsControls:SettingsCard>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer
                Padding="16,16,16,0"
                VerticalScrollBarVisibility="Auto"
                Visibility="{x:Bind ViewModel.IsCutOutWorkflowVisible,
                                    Mode=OneWay,
                                    Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Spacing="12">
                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource OverlayCornerRadius}">
                        <StackPanel Spacing="4">
                            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Extract a region" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="Drag over the image to select a region, then extract it into its own decoding item."
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <InfoBar
                        IsClosable="False"
                        IsOpen="True"
                        Message="Click and drag on the image to draw a region."
                        Severity="Informational" />

                    <settingsControls:SettingsCard Header="Selection status">
                        <StackPanel Spacing="8">
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="No region selected yet."
                                TextWrapping="Wrap"
                                Visibility="{x:Bind ViewModel.HasCutOutSelection,
                                                    Mode=OneWay,
                                                    Converter={StaticResource BoolToVisibilityConverter},
                                                    ConverterParameter=inverse}" />

                            <Grid ColumnSpacing="12" Visibility="{x:Bind ViewModel.HasCutOutSelection, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    Width="28"
                                    Height="28"
                                    Background="{ThemeResource SystemFillColorSuccessBrush}"
                                    CornerRadius="14">
                                    <FontIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                        Glyph="&#xE73E;" />
                                </Border>

                                <TextBlock
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                    Style="{StaticResource BodyStrongTextBlockStyle}"
                                    Text="Region selected and ready to extract."
                                    TextWrapping="Wrap" />
                            </Grid>
                        </StackPanel>
                    </settingsControls:SettingsCard>

                    <settingsControls:SettingsCard Header="Selection">
                        <Button
                            HorizontalAlignment="Stretch"
                            Command="{x:Bind ViewModel.ClearCutOutSelectionCommand}"
                            ToolTipService.ToolTip="Clear the current region selection">
                            <TextBlock Text="Clear selection" />
                        </Button>
                    </settingsControls:SettingsCard>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border
            Grid.Row="1"
            Padding="16"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            Visibility="{x:Bind ViewModel.IsWorkflowPickerVisible,
                                Mode=OneWay,
                                Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.ResetAllSettingsCommand}"
                    IsEnabled="{x:Bind ViewModel.IsProcessing,
                                       Mode=OneWay,
                                       Converter={StaticResource BoolNegationConverter}}"
                    ToolTipService.ToolTip="Reset all quick-fix settings to their defaults">
                    <TextBlock Text="Reset all" />
                </Button>

                <local:IconAndTextHyperlinkButton
                    Grid.Column="1"
                    Command="{x:Bind ViewModel.UndoCommand}"
                    Text="Undo"
                    ToolTipService.ToolTip="Undo the last applied change (Ctrl+Z)">
                    <local:IconAndTextHyperlinkButton.IconSource>
                        <SymbolIconSource Symbol="Undo" />
                    </local:IconAndTextHyperlinkButton.IconSource>
                </local:IconAndTextHyperlinkButton>

                <local:IconAndTextHyperlinkButton
                    Grid.Column="2"
                    Command="{x:Bind ViewModel.RedoCommand}"
                    Text="Redo"
                    ToolTipService.ToolTip="Redo the last undone change (Ctrl+Y)"
                    Visibility="Collapsed">
                    <local:IconAndTextHyperlinkButton.IconSource>
                        <SymbolIconSource Symbol="Redo" />
                    </local:IconAndTextHyperlinkButton.IconSource>
                </local:IconAndTextHyperlinkButton>
            </Grid>
        </Border>

        <Border
            Grid.Row="1"
            Padding="16"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            Visibility="{x:Bind ViewModel.IsSampleBlackPointWorkflowVisible,
                                Mode=OneWay,
                                Converter={StaticResource BoolToVisibilityConverter}}">
            <Button
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.CancelWorkflowCommand}"
                Content="Cancel"
                ToolTipService.ToolTip="Cancel black-point sampling and return to the tool list" />
        </Border>

        <Border
            Grid.Row="1"
            Padding="16"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            Visibility="{x:Bind ViewModel.IsSampleWhitePointWorkflowVisible,
                                Mode=OneWay,
                                Converter={StaticResource BoolToVisibilityConverter}}">
            <Button
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.CancelWorkflowCommand}"
                Content="Cancel"
                ToolTipService.ToolTip="Cancel white-point sampling and return to the tool list" />
        </Border>

        <Border
            Grid.Row="1"
            Padding="16"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            Visibility="{x:Bind ViewModel.IsPerspectiveWorkflowVisible,
                                Mode=OneWay,
                                Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Button
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.ApplyProcessingCommand}"
                    Content="Apply correction"
                    IsEnabled="{x:Bind ViewModel.CanApplyPerspectiveWorkflow,
                                       Mode=OneWay}"
                    Style="{StaticResource AccentButtonStyle}"
                    ToolTipService.ToolTip="Apply the perspective correction and return to the tool list" />

                <Grid Grid.Row="1" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.ClearPerspectiveCornersCommand}"
                        Content="Clear corners" />
                    <Button
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.CancelWorkflowCommand}"
                        Content="Cancel" />
                </Grid>
            </Grid>
        </Border>

        <Border
            Grid.Row="1"
            Padding="16"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            Visibility="{x:Bind ViewModel.IsCutOutWorkflowVisible,
                                Mode=OneWay,
                                Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Button
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.PerformCutOutCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    ToolTipService.ToolTip="Extract the selected region and return to the tool list">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Crop" />
                        <TextBlock Text="Extract region" />
                    </StackPanel>
                </Button>

                <Grid Grid.Row="1" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.ClearCutOutSelectionCommand}"
                        Content="Clear selection" />
                    <Button
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        Command="{x:Bind ViewModel.CancelWorkflowCommand}"
                        Content="Cancel" />
                </Grid>
            </Grid>
        </Border>
    </Grid>

    <UserControl.KeyboardAccelerators>
        <KeyboardAccelerator
            Key="Z"
            Invoked="UndoAccelerator_Invoked"
            Modifiers="Control" />
        <KeyboardAccelerator
            Key="Y"
            Invoked="RedoAccelerator_Invoked"
            Modifiers="Control" />
    </UserControl.KeyboardAccelerators>
</UserControl>
