<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Simple_QR_Code_Maker.Controls.AdvancedToolsUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Simple_QR_Code_Maker.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Simple_QR_Code_Maker.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkitConverters="using:CommunityToolkit.WinUI.Converters"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <toolkitConverters:BoolNegationConverter x:Key="BoolNegationConverter" />
        <toolkitConverters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,12,0,8" />
        </Style>
    </UserControl.Resources>

    <StackPanel Spacing="12">
        <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Advanced Image Processing Tools" />

        <StackPanel
            Padding="12"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="8"
            Spacing="8">
            <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Basic Adjustments" />

            <CheckBox
                x:Name="GrayscaleCheckBox"
                Content="Convert to Grayscale"
                IsChecked="{x:Bind ViewModel.IsGrayscaleEnabled, Mode=TwoWay}"
                ToolTipService.ToolTip="Convert the image to grayscale for better QR code detection" />

            <StackPanel Spacing="4">
                <TextBlock Text="Contrast" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Slider
                        x:Name="ContrastSlider"
                        Grid.Column="0"
                        Maximum="100"
                        Minimum="-100"
                        StepFrequency="1"
                        ToolTipService.ToolTip="Adjust image contrast"
                        Value="{x:Bind ViewModel.ContrastValue, Mode=TwoWay}" />
                    <TextBlock
                        Grid.Column="1"
                        MinWidth="40"
                        VerticalAlignment="Center"
                        Text="{x:Bind ViewModel.ContrastValue, Mode=OneWay}" />
                </Grid>
            </StackPanel>
        </StackPanel>

        <StackPanel
            Padding="12"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="8"
            Spacing="8">
            <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Levels Adjustment" />

            <StackPanel Spacing="4">
                <TextBlock Text="Black Point" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Slider
                        x:Name="BlackPointSlider"
                        Grid.Column="0"
                        Maximum="100"
                        Minimum="0"
                        StepFrequency="1"
                        ToolTipService.ToolTip="Adjust the black point level"
                        Value="{x:Bind ViewModel.BlackPointLevel, Mode=TwoWay}" />
                    <TextBlock
                        Grid.Column="1"
                        MinWidth="40"
                        VerticalAlignment="Center"
                        Text="{x:Bind ViewModel.BlackPointLevel, Mode=OneWay}" />
                </Grid>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="White Point" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Slider
                        x:Name="WhitePointSlider"
                        Grid.Column="0"
                        Maximum="100"
                        Minimum="0"
                        StepFrequency="1"
                        ToolTipService.ToolTip="Adjust the white point level"
                        Value="{x:Bind ViewModel.WhitePointLevel, Mode=TwoWay}" />
                    <TextBlock
                        Grid.Column="1"
                        MinWidth="40"
                        VerticalAlignment="Center"
                        Text="{x:Bind ViewModel.WhitePointLevel, Mode=OneWay}" />
                </Grid>
            </StackPanel>
        </StackPanel>

        <StackPanel
            Padding="12"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="8"
            Spacing="8">
            <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Eyedropper Tools" />

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button
                    Command="{x:Bind ViewModel.ToggleEyedropperBlackModeCommand}"
                    ToolTipService.ToolTip="Click to enable eyedropper, then click on the image to select the black point">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xEF3C;" />
                        <TextBlock Text="Pick Black Point" />
                    </StackPanel>
                </Button>

                <Button
                    Command="{x:Bind ViewModel.ToggleEyedropperWhiteModeCommand}"
                    ToolTipService.ToolTip="Click to enable eyedropper, then click on the image to select the white point">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xEF3C;" />
                        <TextBlock Text="Pick White Point" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>

        <StackPanel
            Padding="12"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="8"
            Spacing="8">
            <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Perspective Correction" />

            <CheckBox
                x:Name="PerspectiveModeCheckBox"
                Content="Enable Perspective Correction Mode"
                IsChecked="{x:Bind ViewModel.IsPerspectiveCorrectionMode, Mode=TwoWay}"
                ToolTipService.ToolTip="Enable to select the 4 corners of the QR code for perspective correction" />

            <TextBlock
                Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                Text="Click on the image to select corners in order: Top-Left, Top-Right, Bottom-Right, Bottom-Left"
                TextWrapping="Wrap"
                Visibility="{x:Bind ViewModel.IsPerspectiveCorrectionMode, Mode=OneWay}" />

            <StackPanel Spacing="4">
                <TextBlock Text="Border Size (pixels)" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Slider
                        x:Name="BorderSlider"
                        Grid.Column="0"
                        Maximum="50"
                        Minimum="0"
                        StepFrequency="1"
                        ToolTipService.ToolTip="Add a white border around the corrected image for better detection"
                        Value="{x:Bind ViewModel.BorderPixels, Mode=TwoWay}" />
                    <TextBlock
                        Grid.Column="1"
                        MinWidth="40"
                        VerticalAlignment="Center"
                        Text="{x:Bind ViewModel.BorderPixels, Mode=OneWay}" />
                </Grid>
            </StackPanel>

            <Button
                Command="{x:Bind ViewModel.ClearPerspectiveCornersCommand}"
                Content="Clear Corner Selection"
                ToolTipService.ToolTip="Clear all selected corners to start over" />
        </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Button
                                    Command="{x:Bind ViewModel.ApplyProcessingCommand}"
                                    Style="{StaticResource AccentButtonStyle}"
                                    ToolTipService.ToolTip="Apply all selected adjustments to the image">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <SymbolIcon Symbol="Accept" />
                                        <TextBlock Text="Apply Changes" />
                                    </StackPanel>
                                </Button>

                                <Button
                                    Command="{x:Bind ViewModel.ResetAllSettingsCommand}"
                                    ToolTipService.ToolTip="Reset all settings to default values">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <SymbolIcon Symbol="Refresh" />
                                        <TextBlock Text="Reset All" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
</UserControl>
