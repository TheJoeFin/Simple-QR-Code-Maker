<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Simple_QR_Code_Maker.Controls.AdvancedToolsUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Simple_QR_Code_Maker.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Simple_QR_Code_Maker.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkitConverters="using:CommunityToolkit.WinUI.Converters"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <converters:MagickColorToBrushConverter x:Key="MagickColorToBrushConverter" />
        <toolkitConverters:BoolNegationConverter x:Key="BoolNegationConverter" />
        <toolkitConverters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,12,0,8" />
        </Style>

        <Style x:Key="ToolToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MinHeight" Value="40" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Scrollable Content  -->
        <ScrollViewer
            Grid.Row="0"
            Padding="12,12,12,0"
            VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="Advanced Image Processing Tools" />

                <StackPanel
                    Padding="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Spacing="8">
                    <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Basic Adjustments" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Apply grayscale, invert, and contrast adjustments for better QR code detection"
                        TextWrapping="Wrap" />

                    <Button
                        Command="{x:Bind ViewModel.ApplyGrayscaleCommand}"
                        IsEnabled="{x:Bind ViewModel.IsProcessing, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                        ToolTipService.ToolTip="Convert the image to grayscale for better QR code detection">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE790;" />
                            <TextBlock Text="Convert to Grayscale" />
                        </StackPanel>
                    </Button>

                    <Button
                        Command="{x:Bind ViewModel.ApplyInvertCommand}"
                        IsEnabled="{x:Bind ViewModel.IsProcessing, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                        ToolTipService.ToolTip="Invert image colors, useful for light QR codes on dark backgrounds">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xE771;" />
                            <TextBlock Text="Invert Colors" />
                        </StackPanel>
                    </Button>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Contrast" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Slider
                                x:Name="ContrastSlider"
                                Grid.Column="0"
                                Maximum="100"
                                Minimum="-100"
                                StepFrequency="1"
                                ToolTipService.ToolTip="Adjust image contrast"
                                Value="{x:Bind ViewModel.ContrastValue,
                                               Mode=TwoWay}" />
                            <TextBlock
                                Grid.Column="1"
                                MinWidth="40"
                                VerticalAlignment="Center"
                                Text="{x:Bind ViewModel.ContrastValue,
                                              Mode=OneWay}" />
                        </Grid>
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    Padding="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Spacing="8">
                    <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Levels Adjustment" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Fine-tune the black and white points to improve image contrast"
                        TextWrapping="Wrap" />

                    <StackPanel Spacing="4">
                        <TextBlock Text="Black Point" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Slider
                                x:Name="BlackPointSlider"
                                Grid.Column="0"
                                Maximum="100"
                                Minimum="0"
                                StepFrequency="1"
                                ToolTipService.ToolTip="Adjust the black point level"
                                Value="{x:Bind ViewModel.BlackPointLevel,
                                               Mode=TwoWay}" />
                            <TextBlock
                                Grid.Column="1"
                                MinWidth="40"
                                VerticalAlignment="Center"
                                Text="{x:Bind ViewModel.BlackPointLevel,
                                              Mode=OneWay}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="White Point" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Slider
                                x:Name="WhitePointSlider"
                                Grid.Column="0"
                                Maximum="100"
                                Minimum="0"
                                StepFrequency="1"
                                ToolTipService.ToolTip="Adjust the white point level"
                                Value="{x:Bind ViewModel.WhitePointLevel,
                                               Mode=TwoWay}" />
                            <TextBlock
                                Grid.Column="1"
                                MinWidth="40"
                                VerticalAlignment="Center"
                                Text="{x:Bind ViewModel.WhitePointLevel,
                                              Mode=OneWay}" />
                        </Grid>
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    Padding="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Spacing="8">
                    <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Eyedropper Tools" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Select colors from the image to set black and white points for better contrast"
                        TextWrapping="Wrap" />

                    <Grid ColumnSpacing="8" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>
                        <ToggleButton
                            Grid.Row="0"
                            Grid.Column="0"
                            HorizontalAlignment="Center"
                            IsChecked="{x:Bind ViewModel.IsEyedropperBlackMode,
                                               Mode=TwoWay}"
                            Style="{StaticResource ToolToggleButtonStyle}"
                            ToolTipService.ToolTip="Click to enable eyedropper, then click on the image to select the black point">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xEF3C;" />
                                <TextBlock Text="Black Point" />
                            </StackPanel>
                        </ToggleButton>

                        <ToggleButton
                            Grid.Row="0"
                            Grid.Column="1"
                            HorizontalAlignment="Center"
                            IsChecked="{x:Bind ViewModel.IsEyedropperWhiteMode,
                                               Mode=TwoWay}"
                            Style="{StaticResource ToolToggleButtonStyle}"
                            ToolTipService.ToolTip="Click to enable eyedropper, then click on the image to select the white point">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xEF3C;" />
                                <TextBlock Text="White Point" />
                            </StackPanel>
                        </ToggleButton>

                        <StackPanel
                            Grid.Row="1"
                            Grid.Column="0"
                            HorizontalAlignment="Center"
                            Spacing="4"
                            Visibility="{x:Bind ViewModel.SelectedBlackPointColor,
                                                Mode=OneWay,
                                                Converter={StaticResource NullToVisibilityConverter}}">
                            <TextBlock FontSize="12" Text="Black Point Color" />
                            <Rectangle
                                Width="60"
                                Height="30"
                                Fill="{x:Bind ViewModel.SelectedBlackPointColor,
                                              Mode=OneWay,
                                              Converter={StaticResource MagickColorToBrushConverter}}"
                                RadiusX="4"
                                RadiusY="4"
                                Stroke="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                StrokeThickness="1" />
                        </StackPanel>


                        <StackPanel
                            Grid.Row="1"
                            Grid.Column="1"
                            HorizontalAlignment="Center"
                            Spacing="4"
                            Visibility="{x:Bind ViewModel.SelectedWhitePointColor,
                                                Mode=OneWay,
                                                Converter={StaticResource NullToVisibilityConverter}}">
                            <TextBlock FontSize="12" Text="White Point Color" />
                            <Rectangle
                                Width="60"
                                Height="30"
                                Fill="{x:Bind ViewModel.SelectedWhitePointColor,
                                              Mode=OneWay,
                                              Converter={StaticResource MagickColorToBrushConverter}}"
                                RadiusX="4"
                                RadiusY="4"
                                Stroke="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                StrokeThickness="1" />
                        </StackPanel>

                        <InfoBar
                            Grid.Row="2"
                            Grid.ColumnSpan="2"
                            IsClosable="False"
                            IsOpen="{x:Bind ViewModel.IsEyedropperBlackMode,
                                            Mode=OneWay}"
                            Message="Click on the image to select the black point"
                            Severity="Informational" />

                        <InfoBar
                            Grid.Row="2"
                            Grid.ColumnSpan="2"
                            IsClosable="False"
                            IsOpen="{x:Bind ViewModel.IsEyedropperWhiteMode,
                                            Mode=OneWay}"
                            Message="Click on the image to select the white point"
                            Severity="Informational" />
                    </Grid>
                </StackPanel>

                <StackPanel
                    Padding="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Spacing="8">
                    <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="Perspective Correction" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Correct perspective distortion by selecting the four corners of the QR code"
                        TextWrapping="Wrap" />

                    <ToggleButton
                        IsChecked="{x:Bind ViewModel.IsPerspectiveCorrectionMode,
                                           Mode=TwoWay}"
                        Style="{StaticResource ToolToggleButtonStyle}"
                        ToolTipService.ToolTip="Enable to select the 4 corners of the QR code for perspective correction">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE91F;" />
                            <TextBlock Text="Enable Perspective Correction and Crop" />
                        </StackPanel>
                    </ToggleButton>

                    <InfoBar
                        IsClosable="False"
                        IsOpen="{x:Bind ViewModel.IsPerspectiveCorrectionMode,
                                        Mode=OneWay}"
                        Message="Click on the image to mark each corner in sequence"
                        Severity="Informational" />

                    <!--  Current step indicator  -->
                    <StackPanel
                        Margin="0,8,0,0"
                        Orientation="Horizontal"
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.IsPerspectiveCorrectionMode,
                                            Mode=OneWay}">

                        <!--  Number badge  -->
                        <Border
                            Width="28"
                            Height="28"
                            Background="{ThemeResource SystemAccentColor}"
                            CornerRadius="14"
                            Visibility="{x:Bind ViewModel.IsCornerSelectionComplete,
                                                Mode=OneWay,
                                                Converter={StaticResource BoolToVisibilityConverter},
                                                ConverterParameter=inverse}">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="14"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="{x:Bind ViewModel.CurrentCornerNumber,
                                              Mode=OneWay}" />
                        </Border>

                        <!--  Success checkmark  -->
                        <Border
                            Width="28"
                            Height="28"
                            Background="{ThemeResource SystemFillColorSuccessBrush}"
                            CornerRadius="14"
                            Visibility="{x:Bind ViewModel.IsCornerSelectionComplete,
                                                Mode=OneWay,
                                                Converter={StaticResource BoolToVisibilityConverter}}">
                            <FontIcon
                                FontSize="14"
                                Foreground="White"
                                Glyph="&#xE73E;" />
                        </Border>

                        <!--  Instruction text  -->
                        <TextBlock
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource SystemAccentColor}"
                            Text="{x:Bind ViewModel.CurrentCornerInstruction,
                                          Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.IsCornerSelectionComplete,
                                                Mode=OneWay,
                                                Converter={StaticResource BoolToVisibilityConverter},
                                                ConverterParameter=inverse}" />

                        <TextBlock
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                            Text="{x:Bind ViewModel.CurrentCornerInstruction,
                                          Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.IsCornerSelectionComplete,
                                                Mode=OneWay,
                                                Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>

                    <StackPanel Spacing="4" Visibility="{x:Bind ViewModel.IsPerspectiveCorrectionMode, Mode=OneWay}">
                        <TextBlock Text="Border Size (pixels)" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Slider
                                x:Name="BorderSlider"
                                Grid.Column="0"
                                Maximum="50"
                                Minimum="0"
                                StepFrequency="1"
                                ToolTipService.ToolTip="Add a white border around the corrected image for better detection"
                                Value="{x:Bind ViewModel.BorderPixels,
                                               Mode=TwoWay}" />
                            <TextBlock
                                Grid.Column="1"
                                MinWidth="40"
                                VerticalAlignment="Center"
                                Text="{x:Bind ViewModel.BorderPixels,
                                              Mode=OneWay}" />
                        </Grid>
                    </StackPanel>

                    <Button
                        Command="{x:Bind ViewModel.ClearPerspectiveCornersCommand}"
                        Content="Clear Corner Selection"
                        ToolTipService.ToolTip="Clear all selected corners to start over" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!--  Fixed Action Buttons  -->
        <StackPanel
            Grid.Row="1"
            Padding="12"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            Orientation="Horizontal"
            Spacing="12">
            <Button
                Command="{x:Bind ViewModel.ApplyProcessingCommand}"
                IsEnabled="{x:Bind ViewModel.IsProcessing,
                                   Mode=OneWay,
                                   Converter={StaticResource BoolNegationConverter}}"
                Style="{StaticResource AccentButtonStyle}"
                ToolTipService.ToolTip="Apply all selected adjustments to the image">
                <Grid>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon
                            FontFamily="{StaticResource SymbolThemeFontFamily}"
                            Glyph="&#xE73E;"
                            Visibility="{x:Bind ViewModel.IsProcessing,
                                                Mode=OneWay,
                                                Converter={StaticResource BoolToVisibilityConverter},
                                                ConverterParameter=inverse}" />
                        <TextBlock Text="Apply Changes" />
                        <TextBlock
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="●"
                            Visibility="{x:Bind ViewModel.HasPendingChanges,
                                                Mode=OneWay,
                                                Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>
                    <ProgressRing
                        Width="16"
                        Height="16"
                        IsActive="{x:Bind ViewModel.IsProcessing,
                                          Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.IsProcessing,
                                            Mode=OneWay,
                                            Converter={StaticResource BoolToVisibilityConverter}}" />
                </Grid>
            </Button>

            <Button
                Command="{x:Bind ViewModel.ResetAllSettingsCommand}"
                IsEnabled="{x:Bind ViewModel.IsProcessing,
                                   Mode=OneWay,
                                   Converter={StaticResource BoolNegationConverter}}"
                ToolTipService.ToolTip="Reset all settings to default values">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <SymbolIcon Symbol="Refresh" />
                    <TextBlock Text="Reset All" />
                </StackPanel>
            </Button>

            <local:IconAndTextHyperlinkButton Command="{x:Bind ViewModel.UndoCommand}" ToolTipService.ToolTip="Undo the last applied change (Ctrl+Z)">
                <local:IconAndTextHyperlinkButton.Icon>
                    <SymbolIcon Symbol="Undo" />
                </local:IconAndTextHyperlinkButton.Icon>
            </local:IconAndTextHyperlinkButton>

            <local:IconAndTextHyperlinkButton
                Command="{x:Bind ViewModel.RedoCommand}"
                ToolTipService.ToolTip="Redo the last undone change (Ctrl+Y)"
                Visibility="Collapsed">
                <local:IconAndTextHyperlinkButton.Icon>
                    <SymbolIcon Symbol="Redo" />
                </local:IconAndTextHyperlinkButton.Icon>
            </local:IconAndTextHyperlinkButton>
        </StackPanel>
    </Grid>

    <UserControl.KeyboardAccelerators>
        <KeyboardAccelerator
            Key="Z"
            Invoked="UndoAccelerator_Invoked"
            Modifiers="Control" />
        <KeyboardAccelerator
            Key="Y"
            Invoked="RedoAccelerator_Invoked"
            Modifiers="Control" />
    </UserControl.KeyboardAccelerators>
</UserControl>
