<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Simple_QR_Code_Maker.Controls.ColorPickerButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Simple_QR_Code_Maker.Controls"
    xmlns:converters="using:Simple_QR_Code_Maker.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkitControls="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:ColorToBrushConverter x:Key="ColorToBrush" />
    </UserControl.Resources>

    <Button Width="48" ToolTipService.ToolTip="Pick color">
        <Button.Flyout>
            <Flyout x:Name="PickerFlyout">
                <StackPanel Spacing="10">

                    <!--  Mode switcher  -->
                    <toolkitControls:Segmented
                        x:Name="ModePicker"
                        HorizontalAlignment="Stretch"
                        SelectedIndex="0">
                        <toolkitControls:SegmentedItem Content="Color" Tag="color">
                            <toolkitControls:SegmentedItem.Icon>
                                <FontIcon Glyph="&#xE790;" />
                            </toolkitControls:SegmentedItem.Icon>
                        </toolkitControls:SegmentedItem>
                        <toolkitControls:SegmentedItem Content="Image" Tag="image">
                            <toolkitControls:SegmentedItem.Icon>
                                <SymbolIcon Symbol="Pictures" />
                            </toolkitControls:SegmentedItem.Icon>
                        </toolkitControls:SegmentedItem>
                    </toolkitControls:Segmented>

                    <toolkitControls:SwitchPresenter Value="{Binding SelectedItem.Tag, ElementName=ModePicker}">
                        <toolkitControls:Case Value="color">
                            <ColorPicker
                                ColorChanged="OnColorPickerColorChanged"
                                ColorSpectrumShape="Ring"
                                IsAlphaEnabled="True"
                                IsMoreButtonVisible="True"
                                Color="{x:Bind Color,
                                               Mode=OneWay}" />
                        </toolkitControls:Case>
                        <toolkitControls:Case Value="image">
                            <controls:ImageColorPickerControl
                                DefaultImagePath="{x:Bind DefaultImagePath,
                                                          Mode=OneWay}"
                                Loaded="OnImagePickerLoaded"
                                Color="{x:Bind Color,
                                               Mode=OneWay}" />
                        </toolkitControls:Case>
                    </toolkitControls:SwitchPresenter>

                </StackPanel>
            </Flyout>
        </Button.Flyout>
        <Rectangle
            Width="16"
            Height="16"
            Fill="{x:Bind Color,
                          Mode=OneWay,
                          Converter={StaticResource ColorToBrush}}" />
    </Button>
</UserControl>
