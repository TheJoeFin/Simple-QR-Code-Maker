<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Simple_QR_Code_Maker.Controls.BrandPickerControl"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Simple_QR_Code_Maker.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Simple_QR_Code_Maker.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Simple_QR_Code_Maker.Models"
    xmlns:toolkitConverters="using:CommunityToolkit.WinUI.Converters"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:EmptyCollectionToVisibilityConverter x:Key="EmptyCollectionToVisibility" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
        <toolkitConverters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <DropDownButton
        Height="36"
        MinWidth="216"
        HorizontalAlignment="Center"
        HorizontalContentAlignment="Stretch"
        ToolTipService.ToolTip="Select brand"
        Visibility="{x:Bind ViewModel.BrandItems.Count,
                            Converter={StaticResource EmptyCollectionToVisibility},
                            ConverterParameter=true,
                            Mode=OneWay}">
        <DropDownButton.Content>
            <Grid>
                <StackPanel
                    Orientation="Horizontal"
                    Spacing="6"
                    Visibility="{Binding ViewModel.SelectedBrand,
                                         ElementName=Root,
                                         Converter={StaticResource NullToVisibility}}">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Text="{Binding ViewModel.SelectedBrand.Name,
                                       ElementName=Root}"
                        TextTrimming="CharacterEllipsis" />
                    <FontIcon
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                        FontSize="12"
                        Glyph="&#xE734;"
                        ToolTipService.ToolTip="Default brand"
                        Visibility="{Binding ViewModel.SelectedBrand.IsDefault,
                                             ElementName=Root,
                                             Converter={StaticResource BoolToVisibility}}" />
                </StackPanel>

                <TextBlock
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Select a brand"
                    Visibility="{Binding ViewModel.SelectedBrand,
                                         ElementName=Root,
                                         Converter={StaticResource NullToVisibility},
                                         ConverterParameter=Inverted}" />
            </Grid>
        </DropDownButton.Content>
        <DropDownButton.Flyout>
            <Flyout x:Name="BrandPickerFlyout" Placement="Bottom">
                <ListView
                    x:Name="BrandPickerListView"
                    Width="320"
                    MaxHeight="360"
                    ItemsSource="{x:Bind ViewModel.BrandItems,
                                         Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedBrand,
                                          Mode=OneWay}"
                    SelectionChanged="BrandPickerListView_SelectionChanged"
                    SelectionMode="Single">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:BrandItem">
                            <local:BrandRowItem
                                Data="{x:Bind}"
                                DeleteRequested="BrandRowItem_DeleteRequested"
                                EditRequested="BrandRowItem_EditRequested"
                                SetDefaultRequested="BrandRowItem_SetDefaultRequested"
                                ShowActions="True" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Flyout>
        </DropDownButton.Flyout>
    </DropDownButton>
</UserControl>
