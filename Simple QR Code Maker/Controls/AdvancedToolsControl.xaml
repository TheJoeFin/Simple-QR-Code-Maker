<UserControl
    x:Class="Simple_QR_Code_Maker.Controls.AdvancedToolsControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Simple_QR_Code_Maker.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:Simple_QR_Code_Maker.ViewModels"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <Style TargetType="TextBlock" x:Key="SectionHeaderStyle">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,12,0,8" />
        </Style>
    </UserControl.Resources>

    <StackPanel Spacing="12">
        <TextBlock Text="Advanced Image Processing Tools" Style="{StaticResource TitleTextBlockStyle}" />
        
        <StackPanel Spacing="8" Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
            <TextBlock Text="Basic Adjustments" Style="{StaticResource SectionHeaderStyle}" />
            
            <CheckBox
                x:Name="GrayscaleCheckBox"
                Content="Convert to Grayscale"
                IsChecked="{x:Bind ViewModel.IsGrayscaleEnabled, Mode=TwoWay}"
                ToolTipService.ToolTip="Convert the image to grayscale for better QR code detection" />

            <StackPanel Spacing="4">
                <TextBlock Text="Contrast" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Slider
                        x:Name="ContrastSlider"
                        Grid.Column="0"
                        Minimum="-100"
                        Maximum="100"
                        Value="{x:Bind ViewModel.ContrastValue, Mode=TwoWay}"
                        StepFrequency="1"
                        ToolTipService.ToolTip="Adjust image contrast" />
                    <TextBlock
                        Grid.Column="1"
                        Text="{x:Bind ViewModel.ContrastValue, Mode=OneWay}"
                        VerticalAlignment="Center"
                        MinWidth="40" />
                </Grid>
            </StackPanel>
        </StackPanel>

        <StackPanel Spacing="8" Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
            <TextBlock Text="Levels Adjustment" Style="{StaticResource SectionHeaderStyle}" />
            
            <StackPanel Spacing="4">
                <TextBlock Text="Black Point" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Slider
                        x:Name="BlackPointSlider"
                        Grid.Column="0"
                        Minimum="0"
                        Maximum="100"
                        Value="{x:Bind ViewModel.BlackPointLevel, Mode=TwoWay}"
                        StepFrequency="1"
                        ToolTipService.ToolTip="Adjust the black point level" />
                    <TextBlock
                        Grid.Column="1"
                        Text="{x:Bind ViewModel.BlackPointLevel, Mode=OneWay}"
                        VerticalAlignment="Center"
                        MinWidth="40" />
                </Grid>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="White Point" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Slider
                        x:Name="WhitePointSlider"
                        Grid.Column="0"
                        Minimum="0"
                        Maximum="100"
                        Value="{x:Bind ViewModel.WhitePointLevel, Mode=TwoWay}"
                        StepFrequency="1"
                        ToolTipService.ToolTip="Adjust the white point level" />
                    <TextBlock
                        Grid.Column="1"
                        Text="{x:Bind ViewModel.WhitePointLevel, Mode=OneWay}"
                        VerticalAlignment="Center"
                        MinWidth="40" />
                </Grid>
            </StackPanel>
        </StackPanel>

        <StackPanel Spacing="8" Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
            <TextBlock Text="Eyedropper Tools" Style="{StaticResource SectionHeaderStyle}" />
            
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button
                    Command="{x:Bind ViewModel.ToggleEyedropperBlackModeCommand}"
                    ToolTipService.ToolTip="Click to enable eyedropper, then click on the image to select the black point">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Eyedropper" />
                        <TextBlock Text="Pick Black Point" />
                    </StackPanel>
                </Button>
                
                <Button
                    Command="{x:Bind ViewModel.ToggleEyedropperWhiteModeCommand}"
                    ToolTipService.ToolTip="Click to enable eyedropper, then click on the image to select the white point">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Eyedropper" />
                        <TextBlock Text="Pick White Point" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                <Border
                    Width="30"
                    Height="30"
                    Background="Black"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Visibility="{x:Bind ViewModel.SelectedBlackPointColor, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"
                    ToolTipService.ToolTip="Selected black point color" />
                
                <Border
                    Width="30"
                    Height="30"
                    Background="White"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Visibility="{x:Bind ViewModel.SelectedWhitePointColor, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"
                    ToolTipService.ToolTip="Selected white point color" />
            </StackPanel>
        </StackPanel>

        <StackPanel Spacing="8" Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8">
            <TextBlock Text="Perspective Correction" Style="{StaticResource SectionHeaderStyle}" />
            
            <CheckBox
                x:Name="PerspectiveModeCheckBox"
                Content="Enable Perspective Correction Mode"
                IsChecked="{x:Bind ViewModel.IsPerspectiveCorrectionMode, Mode=TwoWay}"
                ToolTipService.ToolTip="Enable to select the 4 corners of the QR code for perspective correction" />

            <TextBlock
                Text="Click on the image to select corners in order: Top-Left, Top-Right, Bottom-Right, Bottom-Left"
                TextWrapping="Wrap"
                Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                Visibility="{x:Bind ViewModel.IsPerspectiveCorrectionMode, Mode=OneWay}" />

            <StackPanel Spacing="4">
                <TextBlock Text="Border Size (pixels)" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Slider
                        x:Name="BorderSlider"
                        Grid.Column="0"
                        Minimum="0"
                        Maximum="50"
                        Value="{x:Bind ViewModel.BorderPixels, Mode=TwoWay}"
                        StepFrequency="1"
                        ToolTipService.ToolTip="Add a white border around the corrected image for better detection" />
                    <TextBlock
                        Grid.Column="1"
                        Text="{x:Bind ViewModel.BorderPixels, Mode=OneWay}"
                        VerticalAlignment="Center"
                        MinWidth="40" />
                </Grid>
            </StackPanel>

            <Button
                Command="{x:Bind ViewModel.ClearPerspectiveCornersCommand}"
                Content="Clear Corner Selection"
                ToolTipService.ToolTip="Clear all selected corners to start over" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="12">
            <Button
                Command="{x:Bind ViewModel.ApplyProcessingCommand}"
                Style="{StaticResource AccentButtonStyle}"
                ToolTipService.ToolTip="Apply all selected adjustments to the image">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <SymbolIcon Symbol="Accept" />
                    <TextBlock Text="Apply Changes" />
                </StackPanel>
            </Button>

            <Button
                Command="{x:Bind ViewModel.ResetAllSettingsCommand}"
                ToolTipService.ToolTip="Reset all settings to default values">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <SymbolIcon Symbol="Refresh" />
                    <TextBlock Text="Reset All" />
                </StackPanel>
            </Button>
        </StackPanel>
    </StackPanel>
</UserControl>
