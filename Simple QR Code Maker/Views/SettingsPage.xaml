<Page
    x:Class="Simple_QR_Code_Maker.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Simple_QR_Code_Maker.Controls"
    xmlns:converters="using:Simple_QR_Code_Maker.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:settingsControls="using:CommunityToolkit.WinUI.Controls"
    xmlns:xaml="using:Microsoft.UI.Xaml"
    mc:Ignorable="d">
    <Page.Resources>
        <converters:EnumIsEqualConverter x:Key="EnumIsEqualConverter" />
        <x:Double x:Key="SettingsCardWrapThreshold">320</x:Double>
        <x:Double x:Key="SettingsCardWrapNoIconThreshold">200</x:Double>
    </Page.Resources>
    <Grid Padding="40,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="12">
            <AppBarButton Command="{x:Bind ViewModel.GoHomeCommand}" Icon="Back" />
            <TextBlock x:Uid="Settings_Title" Style="{StaticResource PageTitleStyle}" />
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <StackPanel
                x:Name="ContentArea"
                Margin="80,24,80,40"
                HorizontalAlignment="Stretch"
                Spacing="4">

                <!--  Rate and Review  -->
                <settingsControls:SettingsCard Description="Enjoying the app? Rate it or send me feedback!" Header="Rate and Review">
                    <settingsControls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE735;" />
                    </settingsControls:SettingsCard.HeaderIcon>
                    <RatingControl
                        x:Name="AppRatingControl"
                        IsClearEnabled="False"
                        ValueChanged="AppRatingControl_ValueChanged" />
                </settingsControls:SettingsCard>

                <!--  Personalization  -->
                <TextBlock
                    x:Uid="Settings_Personalization"
                    Margin="0,0,0,4"
                    Style="{ThemeResource SubtitleTextBlockStyle}" />

                <!--  Theme  -->
                <settingsControls:SettingsExpander
                    Description="Select the app theme"
                    Header="Theme"
                    IsExpanded="True">
                    <settingsControls:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE790;" />
                    </settingsControls:SettingsExpander.HeaderIcon>
                    <settingsControls:SettingsExpander.Items>
                        <settingsControls:SettingsCard ContentAlignment="Left">
                            <StackPanel>
                                <RadioButton
                                    x:Uid="Settings_Theme_Light"
                                    Command="{x:Bind ViewModel.SwitchThemeCommand}"
                                    FontSize="15"
                                    GroupName="AppTheme"
                                    IsChecked="{x:Bind ViewModel.ElementTheme,
                                                       Converter={StaticResource EnumIsEqualConverter},
                                                       ConverterParameter=Light,
                                                       Mode=OneWay}">
                                    <RadioButton.CommandParameter>
                                        <xaml:ElementTheme>Light</xaml:ElementTheme>
                                    </RadioButton.CommandParameter>
                                </RadioButton>
                                <RadioButton
                                    x:Uid="Settings_Theme_Dark"
                                    Command="{x:Bind ViewModel.SwitchThemeCommand}"
                                    FontSize="15"
                                    GroupName="AppTheme"
                                    IsChecked="{x:Bind ViewModel.ElementTheme,
                                                       Converter={StaticResource EnumIsEqualConverter},
                                                       ConverterParameter=Dark,
                                                       Mode=OneWay}">
                                    <RadioButton.CommandParameter>
                                        <xaml:ElementTheme>Dark</xaml:ElementTheme>
                                    </RadioButton.CommandParameter>
                                </RadioButton>
                                <RadioButton
                                    x:Uid="Settings_Theme_Default"
                                    Command="{x:Bind ViewModel.SwitchThemeCommand}"
                                    FontSize="15"
                                    GroupName="AppTheme"
                                    IsChecked="{x:Bind ViewModel.ElementTheme,
                                                       Converter={StaticResource EnumIsEqualConverter},
                                                       ConverterParameter=Default,
                                                       Mode=OneWay}">
                                    <RadioButton.CommandParameter>
                                        <xaml:ElementTheme>Default</xaml:ElementTheme>
                                    </RadioButton.CommandParameter>
                                </RadioButton>
                            </StackPanel>
                        </settingsControls:SettingsCard>
                    </settingsControls:SettingsExpander.Items>
                </settingsControls:SettingsExpander>

                <!--  QR Code Settings  -->
                <TextBlock
                    Margin="0,16,0,4"
                    Style="{ThemeResource SubtitleTextBlockStyle}"
                    Text="QR Code" />

                <!--  Multi-line handling  -->
                <settingsControls:SettingsExpander
                    Description="How to handle multiple lines when making QR Codes"
                    Header="Multi-line handling"
                    IsExpanded="True">
                    <settingsControls:SettingsExpander.HeaderIcon>
                        <SymbolIcon Symbol="List" />
                    </settingsControls:SettingsExpander.HeaderIcon>
                    <settingsControls:SettingsExpander.Items>
                        <settingsControls:SettingsCard ContentAlignment="Left">
                            <StackPanel>
                                <RadioButton
                                    Command="{x:Bind ViewModel.SwitchMultiLineModeCommand}"
                                    CommandParameter="OneLineOneCode"
                                    Content="One code for each line"
                                    FontSize="15"
                                    GroupName="MultiLineHandling"
                                    IsChecked="{x:Bind ViewModel.MultiLineCodeMode,
                                                       Converter={StaticResource EnumIsEqualConverter},
                                                       ConverterParameter=OneLineOneCode,
                                                       Mode=OneWay}" />
                                <RadioButton
                                    Command="{x:Bind ViewModel.SwitchMultiLineModeCommand}"
                                    CommandParameter="MultilineOneCode"
                                    Content="Multi-Line in single code"
                                    FontSize="15"
                                    GroupName="MultiLineHandling"
                                    IsChecked="{x:Bind ViewModel.MultiLineCodeMode,
                                                       Converter={StaticResource EnumIsEqualConverter},
                                                       ConverterParameter=MultilineOneCode,
                                                       Mode=OneWay}" />
                            </StackPanel>
                        </settingsControls:SettingsCard>
                    </settingsControls:SettingsExpander.Items>
                </settingsControls:SettingsExpander>

                <!--  Base text  -->
                <settingsControls:SettingsCard Description="Starting text, at start and for newlines" Header="Base text">
                    <settingsControls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE8AC;" />
                    </settingsControls:SettingsCard.HeaderIcon>
                    <TextBox
                        MinWidth="250"
                        PlaceholderText="ex: https://example.com/"
                        Text="{x:Bind ViewModel.BaseText,
                                      Mode=TwoWay,
                                      UpdateSourceTrigger=PropertyChanged}" />
                </settingsControls:SettingsCard>

                <!--  URL warnings  -->
                <settingsControls:SettingsCard Description="Show warnings when QR Codes are not URLs" Header="URL warnings">
                    <settingsControls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE7BA;" />
                    </settingsControls:SettingsCard.HeaderIcon>
                    <ToggleSwitch
                        IsOn="{x:Bind ViewModel.WarnWhenNotUrl,
                                      Mode=TwoWay,
                                      UpdateSourceTrigger=PropertyChanged}"
                        OffContent="Off"
                        OnContent="On" />
                </settingsControls:SettingsCard>

                <!--  Minimum size text  -->
                <settingsControls:SettingsCard Description="Hide the minimum size text on QR codes" Header="Minimum size text">
                    <settingsControls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE8FF;" />
                    </settingsControls:SettingsCard.HeaderIcon>
                    <ToggleSwitch
                        IsOn="{x:Bind ViewModel.HideMinimumSizeText,
                                      Mode=TwoWay,
                                      UpdateSourceTrigger=PropertyChanged}"
                        OffContent="Showing"
                        OnContent="Hidden" />
                </settingsControls:SettingsCard>

                <!--  Save Both button  -->
                <settingsControls:SettingsCard Description="Show the 'Save Both' button for PNG and SVG" Header="Save Both button">
                    <settingsControls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE74E;" />
                    </settingsControls:SettingsCard.HeaderIcon>
                    <ToggleSwitch
                        IsOn="{x:Bind ViewModel.ShowSaveBothButton,
                                      Mode=TwoWay,
                                      UpdateSourceTrigger=PropertyChanged}"
                        OffContent="Hidden"
                        OnContent="Showing" />
                </settingsControls:SettingsCard>

                <!--  Max scan distance  -->
                <settingsControls:SettingsCard Description="{x:Bind ViewModel.MaxScanDistanceText, Mode=OneWay}" Header="Max scan distance at minimum size">
                    <settingsControls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xED5E;" />
                    </settingsControls:SettingsCard.HeaderIcon>
                    <Slider
                        MinWidth="200"
                        IsThumbToolTipEnabled="False"
                        Maximum="5"
                        Minimum=".35"
                        StepFrequency="0.1"
                        Value="{x:Bind ViewModel.MinSizeScanDistanceScaleFactor,
                                       Mode=TwoWay,
                                       UpdateSourceTrigger=PropertyChanged}" />
                </settingsControls:SettingsCard>

                <settingsControls:SettingsCard Description="{x:Bind ViewModel.QrPaddingSettingsDescription, Mode=OneWay}" Header="QR padding">
                    <settingsControls:SettingsCard.HeaderIcon>
                        <controls:RulerIcon />
                    </settingsControls:SettingsCard.HeaderIcon>
                    <Slider
                        MinWidth="200"
                        IsThumbToolTipEnabled="False"
                        Maximum="10"
                        Minimum="0"
                        StepFrequency="1"
                        Value="{x:Bind ViewModel.QrPaddingModules,
                                       Mode=TwoWay,
                                       UpdateSourceTrigger=PropertyChanged}" />
                </settingsControls:SettingsCard>

                <!--  Quick save location  -->
                <settingsControls:SettingsExpander Description="Skip the folder picker and save directly to this folder" Header="Quick save location">
                    <settingsControls:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xED25;" />
                    </settingsControls:SettingsExpander.HeaderIcon>
                    <settingsControls:SettingsExpander.Items>
                        <settingsControls:SettingsCard Header="Folder">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox
                                    MinWidth="250"
                                    IsReadOnly="True"
                                    PlaceholderText="No folder selected"
                                    Text="{x:Bind ViewModel.QuickSaveLocation,
                                                  Mode=OneWay}" />
                                <Button Command="{x:Bind ViewModel.BrowseQuickSaveLocationCommand}" Content="Browse..." />
                                <Button
                                    Command="{x:Bind ViewModel.ClearQuickSaveLocationCommand}"
                                    Content="Clear"
                                    IsEnabled="{x:Bind ViewModel.HasQuickSaveLocation,
                                                       Mode=OneWay}" />
                            </StackPanel>
                        </settingsControls:SettingsCard>
                    </settingsControls:SettingsExpander.Items>
                </settingsControls:SettingsExpander>

                <!--  Data Import/Export  -->
                <TextBlock
                    Margin="0,16,0,4"
                    Style="{ThemeResource SubtitleTextBlockStyle}"
                    Text="Data" />

                <!--  Export  -->
                <settingsControls:SettingsExpander
                    Description="Save settings, history, brands, and logo images to a zip backup file"
                    Header="Export"
                    IsExpanded="True">
                    <settingsControls:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE898;" />
                    </settingsControls:SettingsExpander.HeaderIcon>
                    <Button Command="{x:Bind ViewModel.ExportSettingsCommand}" Content="Export..." />
                    <settingsControls:SettingsExpander.Items>
                        <settingsControls:SettingsCard Header="Include settings">
                            <settingsControls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE713;" />
                            </settingsControls:SettingsCard.HeaderIcon>
                            <CheckBox IsChecked="{x:Bind ViewModel.ExportIncludeSettings, Mode=TwoWay}" />
                        </settingsControls:SettingsCard>
                        <settingsControls:SettingsCard Header="Include brands">
                            <settingsControls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE8F9;" />
                            </settingsControls:SettingsCard.HeaderIcon>
                            <CheckBox IsChecked="{x:Bind ViewModel.ExportIncludeBrands, Mode=TwoWay}" />
                        </settingsControls:SettingsCard>
                        <settingsControls:SettingsCard Header="Include history">
                            <settingsControls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE81C;" />
                            </settingsControls:SettingsCard.HeaderIcon>
                            <CheckBox IsChecked="{x:Bind ViewModel.ExportIncludeHistory, Mode=TwoWay}" />
                        </settingsControls:SettingsCard>
                    </settingsControls:SettingsExpander.Items>
                </settingsControls:SettingsExpander>

                <!--  Import  -->
                <settingsControls:SettingsCard Description="Restore settings, history, brands, and logo images from a backup zip file" Header="Import">
                    <settingsControls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE896;" />
                    </settingsControls:SettingsCard.HeaderIcon>
                    <Button Command="{x:Bind ViewModel.ImportSettingsCommand}" Content="Import..." />
                </settingsControls:SettingsCard>

                <InfoBar
                    x:Name="ImportExportInfoBar"
                    Closed="ImportExportInfoBar_Closed"
                    IsClosable="True"
                    IsOpen="{x:Bind ViewModel.HasImportExportStatus,
                                    Mode=OneWay}"
                    Message="{x:Bind ViewModel.ImportExportStatusMessage,
                                     Mode=OneWay}"
                    Severity="{x:Bind ViewModel.ImportExportStatusSeverity,
                                      Mode=OneWay}" />

                <!--  About  -->
                <TextBlock
                    x:Uid="Settings_About"
                    Margin="0,16,0,4"
                    Style="{ThemeResource SubtitleTextBlockStyle}" />

                <settingsControls:SettingsExpander Description="{x:Bind ViewModel.VersionDescription, Mode=OneWay}" Header="Simple QR Code Maker">
                    <settingsControls:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE946;" />
                    </settingsControls:SettingsExpander.HeaderIcon>
                    <settingsControls:SettingsExpander.Items>
                        <settingsControls:SettingsCard Header="Privacy">
                            <HyperlinkButton x:Uid="SettingsPage_PrivacyTermsLink" />
                        </settingsControls:SettingsCard>
                        <settingsControls:SettingsCard Header="Learn more">
                            <HyperlinkButton Command="{x:Bind ViewModel.GoToMoreInfoCommand}" Content="QR Codes on Wikipedia" />
                        </settingsControls:SettingsCard>
                        <settingsControls:SettingsCard Header="Rate this app">
                            <HyperlinkButton Command="{x:Bind ViewModel.ReviewAppCommand}" Content="Microsoft Store" />
                        </settingsControls:SettingsCard>
                        <settingsControls:SettingsCard Header="Source code">
                            <HyperlinkButton Content="GitHub" NavigateUri="https://github.com/TheJoeFin/Simple-QR-Code-Maker" />
                        </settingsControls:SettingsCard>
                        <settingsControls:SettingsCard Header="Created by">
                            <HyperlinkButton Content="TheJoeFin" NavigateUri="https://github.com/TheJoeFin" />
                        </settingsControls:SettingsCard>
                    </settingsControls:SettingsExpander.Items>
                </settingsControls:SettingsExpander>

                <!--  More Apps  -->
                <settingsControls:SettingsExpander
                    Description="Other free apps by the same developer"
                    Header="More apps by TheJoeFin"
                    IsExpanded="True">
                    <settingsControls:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE8F1;" />
                    </settingsControls:SettingsExpander.HeaderIcon>
                    <settingsControls:SettingsExpander.Items>
                        <settingsControls:SettingsCard Description="Create, edit, and convert icon files" Header="Simple Icon FileMaker">
                            <HyperlinkButton Command="{x:Bind ViewModel.OpenSimpleIconFileMakerCommand}" Content="Microsoft Store" />
                        </settingsControls:SettingsCard>
                        <settingsControls:SettingsCard Description="Copy text from anywhere on your screen" Header="TextGrab">
                            <HyperlinkButton Command="{x:Bind ViewModel.OpenTextGrabCommand}" Content="Microsoft Store" />
                        </settingsControls:SettingsCard>
                        <settingsControls:SettingsCard Header="Website">
                            <HyperlinkButton Content="JoeFinApps.com" NavigateUri="https://joefinapps.com" />
                        </settingsControls:SettingsCard>
                    </settingsControls:SettingsExpander.Items>
                </settingsControls:SettingsExpander>

                <!--  Libraries  -->
                <settingsControls:SettingsExpander Description="Open source libraries used in this app" Header="Libraries">
                    <settingsControls:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE74C;" />
                    </settingsControls:SettingsExpander.HeaderIcon>
                    <settingsControls:SettingsExpander.Items>
                        <settingsControls:SettingsCard Header="ZXing.NET">
                            <HyperlinkButton Content="GitHub" NavigateUri="https://github.com/micjahn/ZXing.Net" />
                        </settingsControls:SettingsCard>
                        <settingsControls:SettingsCard Header="Windows App SDK">
                            <HyperlinkButton Content="GitHub" NavigateUri="https://github.com/microsoft/WindowsAppSDK" />
                        </settingsControls:SettingsCard>
                        <settingsControls:SettingsCard Header="WinUI 3">
                            <HyperlinkButton Content="GitHub" NavigateUri="https://github.com/Microsoft/microsoft-ui-xaml" />
                        </settingsControls:SettingsCard>
                        <settingsControls:SettingsCard Header="WinUIEx">
                            <HyperlinkButton Content="GitHub" NavigateUri="https://github.com/dotMorten/WinUIEx" />
                        </settingsControls:SettingsCard>
                    </settingsControls:SettingsExpander.Items>
                </settingsControls:SettingsExpander>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
