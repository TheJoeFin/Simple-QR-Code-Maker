<Page
    x:Class="Simple_QR_Code_Maker.Views.SpreadsheetImportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Simple_QR_Code_Maker.Models"
    xmlns:settingsControls="using:CommunityToolkit.WinUI.Controls"
    xmlns:tableView="using:WinUI.TableView"
    mc:Ignorable="d">

    <Page.Resources>
        <x:Double x:Key="SettingsCardWrapThreshold">320</x:Double>
        <x:Double x:Key="SettingsCardWrapNoIconThreshold">200</x:Double>
        <Style x:Key="SpreadsheetPreviewCellTextStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
    </Page.Resources>

    <Grid Padding="40,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="1">
            <StackPanel
                Margin="80,24,80,40"
                HorizontalAlignment="Stretch"
                Spacing="12">

                <TextBlock
                    Style="{StaticResource BodyTextStyle}"
                    Text="{x:Bind ViewModel.FileDescription,
                                  Mode=OneWay}"
                    TextWrapping="Wrap" />

                <InfoBar
                    Title="{x:Bind ViewModel.StatusTitle,
                                   Mode=OneWay}"
                    IsClosable="True"
                    IsOpen="{x:Bind ViewModel.IsStatusVisible,
                                    Mode=TwoWay}"
                    Message="{x:Bind ViewModel.StatusMessage,
                                     Mode=OneWay}"
                    Severity="{x:Bind ViewModel.StatusSeverity,
                                      Mode=OneWay}" />

                <settingsControls:SettingsCard Description="Choose whether the first row should be used as the column names." Header="Header row">
                    <settingsControls:SettingsCard.HeaderIcon>
                        <SymbolIcon Symbol="List" />
                    </settingsControls:SettingsCard.HeaderIcon>
                    <ToggleSwitch
                        IsOn="{x:Bind ViewModel.FirstRowIsHeader,
                                      Mode=TwoWay}"
                        OffContent=""
                        OnContent="" />
                </settingsControls:SettingsCard>

                <settingsControls:SettingsExpander
                    Description="{x:Bind ViewModel.IdGenerationDescription, Mode=OneWay}"
                    Header="Generate IDs and save back"
                    IsExpanded="{x:Bind ViewModel.GenerateIdsToSpreadsheet,
                                        Mode=OneWay}">
                    <settingsControls:SettingsExpander.HeaderIcon>
                        <SymbolIcon Symbol="Save" />
                    </settingsControls:SettingsExpander.HeaderIcon>
                    <settingsControls:SettingsExpander.Content>
                        <ToggleSwitch
                            IsOn="{x:Bind ViewModel.GenerateIdsToSpreadsheet,
                                          Mode=TwoWay}"
                            OffContent=""
                            OnContent="" />
                    </settingsControls:SettingsExpander.Content>
                    <settingsControls:SettingsExpander.Items>
                        <settingsControls:SettingsCard Header="ID style">
                            <ComboBox
                                MinWidth="220"
                                HorizontalAlignment="Stretch"
                                IsEnabled="{x:Bind ViewModel.CanConfigureGeneratedIdFormat,
                                                   Mode=OneWay}"
                                ItemsSource="{x:Bind ViewModel.GeneratedIdFormatOptions,
                                                     Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedGeneratedIdFormatOption,
                                                      Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:SpreadsheetGeneratedIdFormatOption">
                                        <TextBlock Text="{x:Bind DisplayName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </settingsControls:SettingsCard>
                        <settingsControls:SettingsCard
                            Description="Only used when ID style is NanoID."
                            Header="NanoID length"
                            Visibility="{x:Bind ViewModel.NanoIdLengthVisibility,
                                                 Mode=OneWay}">
                            <NumberBox
                                MinWidth="220"
                                IsEnabled="{x:Bind ViewModel.IsNanoIdLengthEnabled,
                                                   Mode=OneWay}"
                                Minimum="1"
                                SmallChange="1"
                                SpinButtonPlacementMode="Compact"
                                Value="{x:Bind ViewModel.NanoIdLength,
                                               Mode=TwoWay,
                                               UpdateSourceTrigger=PropertyChanged}" />
                        </settingsControls:SettingsCard>
                    </settingsControls:SettingsExpander.Items>
                </settingsControls:SettingsExpander>

                <settingsControls:SettingsCard Description="{x:Bind ViewModel.ImportCountDescription, Mode=OneWay}" Header="Column to import">
                    <settingsControls:SettingsCard.HeaderIcon>
                        <SymbolIcon Symbol="Switch" />
                    </settingsControls:SettingsCard.HeaderIcon>
                    <ComboBox
                        MinWidth="220"
                        HorizontalAlignment="Stretch"
                        ItemsSource="{x:Bind ViewModel.ColumnNames,
                                             Mode=OneWay}"
                        SelectedIndex="{x:Bind ViewModel.SelectedColumnIndex,
                                               Mode=TwoWay}" />
                </settingsControls:SettingsCard>

                <settingsControls:SettingsCard Description="Optional text to add before each imported line." Header="Text before imported line">
                    <settingsControls:SettingsCard.HeaderIcon>
                        <SymbolIcon Symbol="Link" />
                    </settingsControls:SettingsCard.HeaderIcon>
                    <TextBox
                        MinWidth="260"
                        HorizontalAlignment="Stretch"
                        PlaceholderText="ex: https://"
                        Text="{x:Bind ViewModel.TextBeforeImportedLine,
                                      Mode=TwoWay,
                                      UpdateSourceTrigger=PropertyChanged}" />
                </settingsControls:SettingsCard>

                <settingsControls:SettingsCard Description="Optional text to add after each imported line." Header="Text after imported line">
                    <settingsControls:SettingsCard.HeaderIcon>
                        <SymbolIcon Symbol="Link" />
                    </settingsControls:SettingsCard.HeaderIcon>
                    <TextBox
                        MinWidth="260"
                        HorizontalAlignment="Stretch"
                        PlaceholderText="ex: ?source=qr-code"
                        Text="{x:Bind ViewModel.TextAfterImportedLine,
                                      Mode=TwoWay,
                                      UpdateSourceTrigger=PropertyChanged}" />
                </settingsControls:SettingsCard>

                <settingsControls:SettingsCard Description="Only import unique values after applying any before/after text." Header="Remove duplicates">
                    <settingsControls:SettingsCard.HeaderIcon>
                        <SymbolIcon Symbol="Sort" />
                    </settingsControls:SettingsCard.HeaderIcon>
                    <ToggleSwitch
                        IsOn="{x:Bind ViewModel.RemoveDuplicates,
                                      Mode=TwoWay}"
                        OffContent=""
                        OnContent="" />
                </settingsControls:SettingsCard>

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ViewModel.RowCountDescription,
                                      Mode=OneWay}" />
                    <TextBlock
                        FontSize="12"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                        Text="{x:Bind ViewModel.ImportCountDescription,
                                      Mode=OneWay}" />
                </StackPanel>

                <Button
                    MinWidth="220"
                    HorizontalAlignment="Left"
                    Command="{x:Bind ViewModel.ImportCommand}"
                    IsEnabled="{x:Bind ViewModel.CanImport,
                                       Mode=OneWay}"
                    Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Accept" />
                        <TextBlock Text="{x:Bind ViewModel.ImportButtonText, Mode=OneWay}" />
                    </StackPanel>
                </Button>

                <TextBlock Style="{ThemeResource SubtitleTextBlockStyle}" Text="Preview" />

                <Border
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <tableView:TableView
                        x:Name="PreviewTableView"
                        AutoGenerateColumns="False"
                        CanFilterColumns="True"
                        CanSortColumns="True"
                        IsReadOnly="True"
                        ItemsSource="{x:Bind ViewModel.PreviewTableRows,
                                             Mode=OneWay}"
                        MinColumnWidth="140"
                        ScrollViewer.HorizontalScrollBarVisibility="Auto"
                        ScrollViewer.HorizontalScrollMode="Enabled"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        ScrollViewer.VerticalScrollMode="Enabled"
                        SelectionMode="None" />
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
