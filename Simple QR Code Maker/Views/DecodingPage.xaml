<Page
    x:Class="Simple_QR_Code_Maker.Views.DecodingPage"
    x:Name="DecodingPageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Simple_QR_Code_Maker.Controls"
    xmlns:converters="using:Simple_QR_Code_Maker.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Simple_QR_Code_Maker.Models"
    xmlns:toolkitConverters="using:CommunityToolkit.WinUI.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:TextHasURLConverter x:Key="HasURL" />
        <converters:IsZeroConverter x:Key="IsZero" />
        <converters:EmptyCollectionToVisibilityConverter x:Key="EmptyCollectionToVisibility" />
        <converters:BoolToAdvancedToolsMessageConverter x:Key="BoolToAdvancedToolsMessageConverter" />
        <converters:NoCodesWarningVisibilityConverter x:Key="NoCodesWarningVisibilityConverter" />
        <toolkitConverters:BoolNegationConverter x:Key="BoolNegationConverter" />
        <toolkitConverters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <ScrollViewer
            x:Name="ImageScrollViewer"
            Grid.Column="0"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto"
            ZoomMode="Disabled">
            <StackPanel
                x:Name="ContentArea"
                Margin="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Vertical"
                Spacing="12">
                <Border
                    x:Name="GridViewContainer"
                    Grid.Row="1"
                    MinWidth="300"
                    MinHeight="300"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    AllowDrop="True"
                    Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
                    CornerRadius="4"
                    DragOver="GridViewContainer_DragOver"
                    Drop="GridViewContainer_Drop">
                    <GridView
                        Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        ItemsSource="{x:Bind ViewModel.DecodingImageItems, Mode=OneWay}"
                        ScrollViewer.IsHorizontalScrollChainingEnabled="True"
                        ScrollViewer.IsVerticalScrollChainingEnabled="True"
                        SelectionMode="None">
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="models:DecodingImageItem">
                                <StackPanel
                                    MaxWidth="400"
                                    Margin="20"
                                    Spacing="8">
                                    <TextBlock x:Name="ImageTextName" Text="{x:Bind FileName, Mode=OneWay}" />
                                    <Viewbox MaxHeight="400">
                                        <Grid x:Name="ImageContainer" PointerPressed="ImageContainer_PointerPressed">
                                            <Image x:Name="ImageWithBarcodes" Source="{x:Bind BitmapImage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <ItemsControl ItemsSource="{x:Bind CodeBorders, Mode=OneWay}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Canvas
                                                            Width="{Binding ImageWithBarcodes.Width}"
                                                            Height="{Binding ImageWithBarcodes.Height}"
                                                            Background="Transparent" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <ContentControl />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Viewbox>

                                    <!--  Info Button (shown when warning is dismissed and no codes found)  -->
                                    <HyperlinkButton
                                        x:Name="ShowInfoButton"
                                        HorizontalAlignment="Center"
                                        Click="ShowNoCodesInfo_Click"
                                        Tag="{x:Bind}"
                                        Visibility="Collapsed">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon FontSize="16" Glyph="&#xE946;" />
                                            <TextBlock Text="Why no codes detected?" />
                                        </StackPanel>
                                        <HyperlinkButton.Resources>
                                            <SolidColorBrush x:Key="HyperlinkButtonForeground" Color="{ThemeResource SystemAccentColor}" />
                                        </HyperlinkButton.Resources>
                                    </HyperlinkButton>

                                    <!--  Warning InfoBar (below image, shown when no codes and not dismissed)  -->
                                    <InfoBar
                                        x:Name="NoCodesInfoBar"
                                        Title="No codes found"
                                        IsClosable="False"
                                        IsOpen="True"
                                        Severity="Warning"
                                        Visibility="{x:Bind CodeBorders.Count, Mode=OneWay, Converter={StaticResource NoCodesWarningVisibilityConverter}}">
                                        <InfoBar.ActionButton>
                                            <Button
                                                Click="DismissNoCodesWarning_Click"
                                                Content="Dismiss"
                                                Tag="{x:Bind}" />
                                        </InfoBar.ActionButton>
                                        <TextBlock
                                            IsTextSelectionEnabled="True"
                                            Text="{Binding ElementName=DecodingPageRoot, Path=ViewModel.IsAdvancedToolsVisible, Converter={StaticResource BoolToAdvancedToolsMessageConverter}, Mode=OneWay}"
                                            TextWrapping="Wrap" />
                                    </InfoBar>
                                </StackPanel>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </Border>

                <StackPanel
                    Grid.Row="0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="12">
                    <Button Command="{x:Bind ViewModel.GoBackCommand}" ToolTipService.ToolTip="Go Back to making QR Code page">
                        <Viewbox Height="18">
                            <SymbolIcon Symbol="Back" />
                        </Viewbox>
                    </Button>
                    <controls:IconAndTextButton
                        Command="{x:Bind ViewModel.OpenNewFileCommand}"
                        IsEnabled="{x:Bind ViewModel.OpenNewFileCommand.IsRunning, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                        Text="Open..."
                        ToolTipService.ToolTip="Open one or many files to decode the barcodes contained in the image">
                        <controls:IconAndTextButton.Icon>
                            <SymbolIcon Symbol="OpenFile" />
                        </controls:IconAndTextButton.Icon>
                    </controls:IconAndTextButton>
                                <controls:IconAndTextButton
                                    Command="{x:Bind ViewModel.OpenFileFromClipboardCommand}"
                                    IsEnabled="{x:Bind ViewModel.CanPasteImage, Mode=OneWay}"
                                    Text="Paste"
                                    ToolTipService.ToolTip="Paste and image or file from your clipboard to try to decode the barcodes">
                                    <controls:IconAndTextButton.Icon>
                                        <SymbolIcon Symbol="Paste" />
                                    </controls:IconAndTextButton.Icon>
                                </controls:IconAndTextButton>
                                <controls:IconAndTextButton
                                    Command="{x:Bind ViewModel.ClearImagesCommand}"
                                    IsEnabled="{x:Bind ViewModel.OpenFileFromClipboardCommand.IsRunning, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"
                                    Text="Clear"
                                    ToolTipService.ToolTip="Clear out all the images"
                                    Visibility="{x:Bind ViewModel.DecodingImageItems.Count, Converter={StaticResource EmptyCollectionToVisibility}, ConverterParameter=true, Mode=OneWay}">
                                    <controls:IconAndTextButton.Icon>
                                        <SymbolIcon Symbol="Clear" />
                                    </controls:IconAndTextButton.Icon>
                                </controls:IconAndTextButton>
                                <ToggleButton
                                    IsChecked="{x:Bind ViewModel.IsAdvancedToolsVisible, Mode=TwoWay}"
                                    ToolTipService.ToolTip="Toggle advanced image processing tools"
                                    Visibility="{x:Bind ViewModel.DecodingImageItems.Count, Converter={StaticResource EmptyCollectionToVisibility}, ConverterParameter=true, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <SymbolIcon Symbol="Repair" />
                                        <TextBlock Text="Advanced Tools" />
                                    </StackPanel>
                                </ToggleButton>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                        <!--  Advanced Tools Panel on the right  -->
                        <Border
                            Grid.Column="1"
                            Width="350"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1,0,0,0"
                            Visibility="{x:Bind ViewModel.IsAdvancedToolsVisible, Mode=OneWay}">
                            <controls:AdvancedToolsUserControl x:Name="AdvancedToolsPanel" />
                        </Border>

                        <InfoBar
                            x:Name="QrCodeInfoBar"
                            Title="QR Code Content"
                            Grid.Column="0"
                            Margin="20"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Background="{StaticResource SystemControlBackgroundAltHighBrush}"
                            BorderBrush="{StaticResource SystemAccentColor}"
            BorderThickness="3"
            IsOpen="{x:Bind ViewModel.IsInfoBarShowing, Mode=TwoWay}"
            Severity="Informational">
            <StackPanel
                Margin="12,0"
                Orientation="Vertical"
                Spacing="12">
                <TextBlock
                    MaxWidth="500"
                    VerticalAlignment="Center"
                    IsTextSelectionEnabled="True"
                    Text="{x:Bind ViewModel.InfoBarMessage, Mode=OneWay}"
                    TextWrapping="Wrap" />
                <StackPanel
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="12">
                    <AppBarButton
                        Command="{x:Bind ViewModel.EditQrCodeCommand}"
                        Icon="Edit"
                        IsCompact="True"
                        ToolTipService.ToolTip="Edit this text as a new QR Code" />
                    <AppBarButton
                        Command="{x:Bind ViewModel.AddMessageToClipboardCommand}"
                        Icon="Copy"
                        IsCompact="True"
                        ToolTipService.ToolTip="Copy the encoded text to the clipboard" />
                    <AppBarButton
                        Command="{x:Bind ViewModel.TryLaunchLinkCommand}"
                        Icon="Go"
                        IsCompact="True"
                        IsEnabled="{x:Bind ViewModel.InfoBarMessage, Mode=OneWay, Converter={StaticResource HasURL}}"
                        ToolTipService.ToolTip="Try to go to the URL" />
                </StackPanel>
            </StackPanel>
        </InfoBar>
    </Grid>
</Page>
